<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600;700&family=Sarabun:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/admin.css">
    <link rel="stylesheet" href="/css/createUser.css">
</head>
<body>
    <div class="admin-container">
        <a href="/admin/users" class="back-btn">
            <i class="fas fa-arrow-left"></i>
            กลับสู่รายการผู้ใช้
        </a>
        
        <div class="form-container">
            <div class="form-header">
                <h1 class="form-title">
                    <i class="fas fa-user-plus"></i>
                    <%= title %>
                </h1>
                <p class="form-subtitle">เพิ่มผู้ใช้ใหม่เข้าสู่ระบบ</p>
            </div>
            
            <% if (errors && errors.length > 0) { %>
                <div class="error-message">
                    <i class="fas fa-exclamation-triangle"></i>
                    <div>
                        <% errors.forEach(function(error) { %>
                            <div><%= error %></div>
                        <% }); %>
                    </div>
                </div>
            <% } %>
            
            <form method="POST" action="/admin/users/create" id="createUserForm">
                <div class="form-row">
                    <div class="form-group">
                        <label for="username" class="form-label">
                            <i class="fas fa-user"></i>
                            ชื่อผู้ใช้ *
                        </label>
                        <input type="text" name="username" id="username" class="form-control"
                               value="<%= formData && formData.username ? formData.username : '' %>"
                               placeholder="กรอกชื่อผู้ใช้" required>
                    </div>
                    
                    <div class="form-group">
                        <label for="email" class="form-label">
                            <i class="fas fa-envelope"></i>
                            อีเมล *
                        </label>
                        <input type="email" name="email" id="email" class="form-control"
                               value="<%= formData && formData.email ? formData.email : '' %>"
                               placeholder="example@email.com" required>
                    </div>
                </div>
                
                <div class="form-group">
                    <label for="fullname" class="form-label">
                        <i class="fas fa-id-card"></i>
                        ชื่อ-นามสกุล *
                    </label>
                    <input type="text" name="fullname" id="fullname" class="form-control"
                           value="<%= formData && formData.fullname ? formData.fullname : '' %>"
                           placeholder="กรอกชื่อ-นามสกุลภาษาไทย" required>
                </div>
                
                <div class="form-group">
                    <label for="password" class="form-label">
                        <i class="fas fa-lock"></i>
                        รหัสผ่าน *
                    </label>
                    <div class="password-input-wrapper">
                        <input type="password" name="password" id="password" class="form-control"
                               placeholder="กรอกรหัสผ่าน (อย่างน้อย 6 ตัวอักษร)" required
                               minlength="6">
                        <button type="button" class="toggle-password" onclick="togglePassword('password')">
                            <i class="fas fa-eye" id="password-eye"></i>
                        </button>
                    </div>
                </div>
                
                <div class="form-group">
                    <label for="role" class="form-label">
                        <i class="fas fa-user-tag"></i>
                        ระดับผู้ใช้ *
                    </label>
                    <select name="role" id="role" class="form-control" required>
                        <option value="">-- เลือกระดับผู้ใช้ --</option>
                        <option value="staff" <%= formData && formData.role === 'staff' ? 'selected' : '' %>>
                            Staff - เจ้าหน้าที่
                        </option>
                        <option value="physical_therapist" <%= formData && formData.role === 'physical_therapist' ? 'selected' : '' %>>
                            Physical Therapist - นักกายภาพบำบัด
                        </option>
                        <option value="admin" <%= formData && formData.role === 'admin' ? 'selected' : '' %>>
                            Admin - ผู้ดูแลระบบ
                        </option>
                    </select>
                </div>
                
                <div style="text-align: center; margin-top: 30px;">
                    <button type="submit" class="btn-submit">
                        <i class="fas fa-user-plus"></i>
                        เพิ่มผู้ใช้ใหม่
                    </button>
                    <a href="/admin/users" class="btn-cancel">
                        <i class="fas fa-times"></i>
                        ยกเลิก
                    </a>
                </div>
            </form>
        </div>
    </div>
    
    <script>
        // Toggle password visibility
        function togglePassword(fieldId) {
            const field = document.getElementById(fieldId);
            const eye = document.getElementById(fieldId + '-eye');
            
            if (field.type === 'password') {
                field.type = 'text';
                eye.classList.remove('fa-eye');
                eye.classList.add('fa-eye-slash');
            } else {
                field.type = 'password';
                eye.classList.remove('fa-eye-slash');
                eye.classList.add('fa-eye');
            }
        }
        
        // Form validation
        document.getElementById('createUserForm').addEventListener('submit', function(e) {
            const passwordInput = document.getElementById('password');
            const password = passwordInput.value;
            
            if (password.length < 6) {
                e.preventDefault();
                alert('รหัสผ่านต้องมีอย่างน้อย 6 ตัวอักษร');
                passwordInput.focus();
                return false;
            }
        });
    </script>
</body>
</html>
