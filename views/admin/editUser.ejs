<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600;700&family=Sarabun:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/admin.css">
    <style>
        .admin-container {
            max-width: 800px;
            margin: 0 auto;
            padding: 20px;
        }
        
        .form-container {
            background: white;
            border-radius: 12px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.1);
            padding: 40px;
        }
        
        .form-header {
            text-align: center;
            margin-bottom: 30px;
        }
        
        .form-title {
            font-size: 2rem;
            color: #2c3e50;
            margin: 0 0 10px 0;
        }
        
        .form-subtitle {
            color: #7f8c8d;
            margin: 0;
        }
        
        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 20px;
        }
        
        .form-group {
            margin-bottom: 20px;
        }
        
        .form-label {
            display: block;
            margin-bottom: 8px;
            font-weight: 500;
            color: #2c3e50;
        }
        
        .form-control {
            width: 100%;
            padding: 12px 16px;
            border: 2px solid #e9ecef;
            border-radius: 8px;
            font-size: 1rem;
            transition: border-color 0.3s ease;
            box-sizing: border-box;
        }
        
        .form-control:focus {
            outline: none;
            border-color: var(--primary-color);
            box-shadow: 0 0 0 3px rgba(0, 137, 123, 0.1);
        }
        
        .form-control[readonly] {
            background-color: #f8f9fa;
            color: #6c757d;
        }
        
        .error-message {
            background: linear-gradient(135deg, #ffb3ba, #ff9a9e);
            color: #2c3e50;
            padding: 12px 20px;
            border-radius: 8px;
            margin-bottom: 20px;
            border: none;
        }
        
        .error-message i {
            margin-right: 8px;
        }
        
        .btn-submit, .btn-cancel {
            padding: 12px 24px;
            border: none;
            border-radius: var(--radius-md);
            font-size: 1rem;
            font-weight: 500;
            cursor: pointer;
            transition: var(--transition);
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            margin-right: 10px;
            box-shadow: var(--shadow-sm);
        }

        .btn-submit {
            background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
            color: white;
        }

        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-hover);
            background: linear-gradient(135deg, var(--primary-light) 0%, var(--primary-color) 100%);
        }

        .btn-cancel {
            background: white;
            color: var(--text-secondary);
            border: 2px solid var(--border-color);
        }

        .btn-cancel:hover {
            background: #f5f5f5;
            border-color: #bdbdbd;
            color: var(--text-primary);
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
        }
        
        .password-input-wrapper {
            position: relative;
        }
        
        .toggle-password {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            color: var(--text-light);
            cursor: pointer;
            padding: 4px;
            transition: var(--transition);
        }

        .toggle-password:hover {
            color: var(--primary-color);
        }
        
        .password-match {
            margin-top: 8px;
            font-size: 0.9rem;
        }
        
        .password-match.match {
            color: #27ae60;
        }
        
        .password-match.no-match {
            color: #e74c3c;
        }
        
        .password-note {
            font-size: 0.9rem;
            color: #7f8c8d;
            margin-top: 5px;
        }
    </style>
</head>
<body>
    <div class="admin-container">
        <a href="/admin/users" class="back-btn">
            <i class="fas fa-arrow-left"></i>
            กลับสู่รายการผู้ใช้
        </a>
        
        <div class="form-container">
            <div class="form-header">
                <h1 class="form-title">
                    <i class="fas fa-user-edit"></i>
                    <%= title %>
                </h1>
                <p class="form-subtitle">แก้ไขข้อมูลผู้ใช้: <%= editUser.username %></p>
            </div>
            
            <% if (errors && errors.length > 0) { %>
                <div class="error-message">
                    <i class="fas fa-exclamation-triangle"></i>
                    <div>
                        <% errors.forEach(function(error) { %>
                            <div><%= error %></div>
                        <% }); %>
                    </div>
                </div>
            <% } %>
            
            <form method="POST" action="/admin/users/<%= editUser.id %>/edit" id="editUserForm">
                <div class="form-group">
                    <label for="username" class="form-label">
                        <i class="fas fa-user"></i>
                        ชื่อผู้ใช้
                    </label>
                    <input type="text" class="form-control" value="<%= editUser.username %>" readonly>
                    <div class="password-note">ไม่สามารถแก้ไขชื่อผู้ใช้ได้</div>
                </div>
                
                <div class="form-row">
                    <div class="form-group">
                        <label for="fullname" class="form-label">
                            <i class="fas fa-id-card"></i>
                            ชื่อ-นามสกุล *
                        </label>
                        <input type="text" name="fullname" id="fullname" class="form-control"
                               value="<%= formData && formData.fullname ? formData.fullname : editUser.fullname %>"
                               placeholder="กรอกชื่อ-นามสกุลภาษาไทย" required>
                    </div>
                    
                    <div class="form-group">
                        <label for="email" class="form-label">
                            <i class="fas fa-envelope"></i>
                            อีเมล *
                        </label>
                        <input type="email" name="email" id="email" class="form-control"
                               value="<%= formData && formData.email ? formData.email : editUser.email %>"
                               placeholder="example@email.com" required>
                    </div>
                </div>
                
                <div class="form-group">
                    <label for="role" class="form-label">
                        <i class="fas fa-user-tag"></i>
                        ระดับผู้ใช้ *
                    </label>
                    <select name="role" id="role" class="form-control" required>
                        <option value="">-- เลือกระดับผู้ใช้ --</option>
                        <option value="staff" <%= (formData && formData.role === 'staff') || editUser.role === 'staff' ? 'selected' : '' %>>
                            Staff - เจ้าหน้าที่
                        </option>
                        <option value="physical_therapist" <%= (formData && formData.role === 'physical_therapist') || editUser.role === 'physical_therapist' ? 'selected' : '' %>>
                            Physical Therapist - นักกายภาพบำบัด
                        </option>
                        <option value="admin" <%= (formData && formData.role === 'admin') || editUser.role === 'admin' ? 'selected' : '' %>>
                            Admin - ผู้ดูแลระบบ
                        </option>
                    </select>
                </div>
                
                <div class="form-row">
                    <div class="form-group">
                        <label for="password" class="form-label">
                            <i class="fas fa-lock"></i>
                            รหัสผ่านใหม่ (ไม่บังคับ)
                        </label>
                        <div class="password-input-wrapper">
                            <input type="password" name="password" id="password" class="form-control"
                                   placeholder="กรอกรหัสผ่านใหม่ (ถ้าต้องการเปลี่ยน)">
                            <button type="button" class="toggle-password" onclick="togglePassword('password')">
                                <i class="fas fa-eye" id="password-eye"></i>
                            </button>
                        </div>
                        <div class="password-note">ปล่อยว่างไว้ถ้าไม่ต้องการเปลี่ยนรหัสผ่าน</div>
                    </div>
                    
                    <div class="form-group">
                        <label for="confirmPassword" class="form-label">
                            <i class="fas fa-lock"></i>
                            ยืนยันรหัสผ่านใหม่
                        </label>
                        <div class="password-input-wrapper">
                            <input type="password" name="confirmPassword" id="confirmPassword" class="form-control"
                                   placeholder="กรอกรหัสผ่านใหม่อีกครั้ง">
                            <button type="button" class="toggle-password" onclick="togglePassword('confirmPassword')">
                                <i class="fas fa-eye" id="confirmPassword-eye"></i>
                            </button>
                        </div>
                        <div class="password-match" id="password-match"></div>
                    </div>
                </div>
                
                <div style="text-align: center; margin-top: 30px;">
                    <button type="submit" class="btn-submit">
                        <i class="fas fa-save"></i>
                        บันทึกการเปลี่ยนแปลง
                    </button>
                    <a href="/admin/users" class="btn-cancel">
                        <i class="fas fa-times"></i>
                        ยกเลิก
                    </a>
                </div>
            </form>
        </div>
    </div>
    
    <script>
        // Toggle password visibility
        function togglePassword(fieldId) {
            const field = document.getElementById(fieldId);
            const eye = document.getElementById(fieldId + '-eye');
            
            if (field.type === 'password') {
                field.type = 'text';
                eye.classList.remove('fa-eye');
                eye.classList.add('fa-eye-slash');
            } else {
                field.type = 'password';
                eye.classList.remove('fa-eye-slash');
                eye.classList.add('fa-eye');
            }
        }
        
        // Check password match
        const passwordInput = document.getElementById('password');
        const confirmPasswordInput = document.getElementById('confirmPassword');
        
        function checkPasswordMatch() {
            const password = passwordInput.value;
            const confirmPassword = confirmPasswordInput.value;
            const matchDiv = document.getElementById('password-match');
            
            if (confirmPassword.length === 0 && password.length === 0) {
                matchDiv.textContent = '';
                matchDiv.className = 'password-match';
                return;
            }
            
            if (password.length > 0 && confirmPassword.length === 0) {
                matchDiv.textContent = 'กรุณายืนยันรหัสผ่าน';
                matchDiv.className = 'password-match no-match';
                return;
            }
            
            if (password === confirmPassword) {
                matchDiv.textContent = '✓ รหัสผ่านตรงกัน';
                matchDiv.className = 'password-match match';
            } else {
                matchDiv.textContent = '✗ รหัสผ่านไม่ตรงกัน';
                matchDiv.className = 'password-match no-match';
            }
        }
        
        passwordInput.addEventListener('input', checkPasswordMatch);
        confirmPasswordInput.addEventListener('input', checkPasswordMatch);
        
        // Form validation
        document.getElementById('editUserForm').addEventListener('submit', function(e) {
            const password = passwordInput.value;
            const confirmPassword = confirmPasswordInput.value;
            
            if (password.length > 0 && password.length < 6) {
                e.preventDefault();
                alert('รหัสผ่านต้องมีอย่างน้อย 6 ตัวอักษร');
                passwordInput.focus();
                return false;
            }
            
            if (password !== confirmPassword) {
                e.preventDefault();
                alert('รหัสผ่านไม่ตรงกัน กรุณาตรวจสอบอีกครั้ง');
                confirmPasswordInput.focus();
                return false;
            }
        });
    </script>
</body>
</html>
