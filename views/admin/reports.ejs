                </div>
            </div>
            
            <div class="stat-card" data-delay="0.5">
                <div class="stat-icon appointments-stat">
                    <i class="fas fa-calendar-check"></i>
                </div>
                <div class="stat-details">
                    <h3><%= stats.todayAppointments || 0 %></h3>
                    <p>นัดหมายวันนี้</p>
                </div>
            </div>
            
            <div class="stat-card" data-delay="0.6">
                <div class="stat-icon revenue-stat">
                    <i class="fas fa-chart-line"></i>
                </div>
                <div class="stat-details">
                    <h3><%= (stats.thisMonthRevenue || 0).toLocaleString() %></h3>
                    <p>รายได้เดือนนี้ (บาท)</p>
                </div>
            </div>
            <div class="stat-card" data-delay="0.7">
                <div class="stat-icon treatments-stat">
                    <i class="fas fa-heartbeat"></i>
                </div>
                <div class="stat-details">
                    <h3 class="stat-number"><%= stats.thisMonthExaminations || 0 %></h3>
                    <p class="stat-label">การรักษาเดือนนี้</p>
                </div>
            </div>
        </div>
        
        <!-- กราฟและแผนภูมิ -->
        <div class="charts-section">
            <div class="chart-card">
                <h2 class="chart-title">
                    <i class="fas fa-chart-pie"></i>
                    สถิติการรักษา
                </h2>
                <div style="position: relative; height: 300px; padding: 20px;">
                    <canvas id="treatmentStatsChart"></canvas>
                </div>
            </div>
        </div>
        
