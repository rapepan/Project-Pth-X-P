    </div>
    
    <script>
        // Animation for stat cards
        const observerOptions = {
            threshold: 0.1,
            rootMargin: '0px 0px -50px 0px'
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.style.opacity = '1';
                    entry.target.style.transform = 'translateY(0)';
                }
            });
        }, observerOptions);

        document.querySelectorAll('.stat-card').forEach(card => {
            card.style.opacity = '0';
            card.style.transform = 'translateY(20px)';
            card.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
            observer.observe(card);
        });

        // สร้างกราฟสถิติการรักษา (Pie Chart)
        const treatmentCtx = document.getElementById('treatmentStatsChart').getContext('2d');
        const treatmentChart = new Chart(treatmentCtx, {
            type: 'pie',
            data: {
                labels: ['ผู้ป่วยทั้งหมด', 'การรักษาเดือนนี้'],
                datasets: [{
                    data: [
                        <%= stats.totalPatients || 0 %>,
                        <%= stats.thisMonthExaminations || 0 %>,
                        <%= stats.todayAppointments || 0 %>
                    ],
                    backgroundColor: [
                        'rgba(54, 162, 235, 0.8)',
                        'rgba(75, 192, 192, 0.8)',
                        'rgba(255, 206, 86, 0.8)'
                    ],
                    borderColor: [
                        'rgba(54, 162, 235, 1)',
                        'rgba(75, 192, 192, 1)',
                        'rgba(255, 206, 86, 1)'
                    ],
                    borderWidth: 2
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: {
                            font: {
                                family: 'Prompt, sans-serif',
                                size: 12
                            },
                            padding: 15
                        }
                    },
                    title: {
                        display: false
                    }
                }
            }
        });

        // ฟังก์ชันสำหรับการดาวน์โหลดรายงาน PDF
        document.querySelectorAll('.btn-generate').forEach(btn => {
            btn.addEventListener('click', async function(e) {
                e.preventDefault();
                
                const originalText = this.innerHTML;
                this.innerHTML = '<i class="fas fa-spinner fa-spin"></i> กำลังสร้าง PDF...';
                this.style.pointerEvents = 'none';
                
                try {
                    // สำหรับ PDF ให้เปิดในหน้าต่างใหม่
                    window.open(this.href, '_blank');
                    
                    // แสดงข้อความสำเร็จ
                    this.innerHTML = '<i class="fas fa-check"></i> กำลังดาวน์โหลด';
                    this.style.background = 'linear-gradient(135deg, #4CAF50, #45a049)';
                    
                    setTimeout(() => {
                        this.innerHTML = originalText;
                        this.style.background = '';
                        this.style.pointerEvents = '';
                    }, 3000);
                } catch (error) {
                    console.error('Error generating PDF:', error);
                    this.innerHTML = '<i class="fas fa-exclamation-triangle"></i> เกิดข้อผิดพลาด';
                    this.style.background = 'linear-gradient(135deg, #f44336, #da190b)';
                    
                    setTimeout(() => {
                        this.innerHTML = originalText;
                        this.style.background = '';
                        this.style.pointerEvents = '';
                    }, 3000);
                }
            });
        });
    </script>
</body>
