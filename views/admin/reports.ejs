                </div>
                <div class="stat-details">
                    <h3><%= stats.usersByRole?.physical_therapist || 0 %></h3>
                    <p>นักกายภาพบำบัด</p>
                </div>
            </div>
            
            <div class="stat-card" data-delay="0.3">
                <div class="stat-icon staff-stat">
                    <i class="fas fa-user"></i>
                </div>
                <div class="stat-details">
                    <h3><%= stats.usersByRole?.staff || 0 %></h3>
                    <p>เจ้าหน้าที่</p>
                </div>
            </div>
            
            <div class="stat-card" data-delay="0.4">
                <div class="stat-icon patients-stat">
