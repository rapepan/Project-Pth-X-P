<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600;700&family=Sarabun:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/index.css">
    <style>
        .admin-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }
        
        .back-btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: #7f8c8d;
            text-decoration: none;
            margin-bottom: 20px;
            transition: color 0.3s ease;
        }
        
        .back-btn:hover {
            color: #2c3e50;
        }
        
        .page-header {
            text-align: center;
            margin-bottom: 40px;
            padding-bottom: 20px;
            border-bottom: 2px solid #e9ecef;
        }
        
        .page-title {
            font-size: 2.5rem;
            color: #2c3e50;
            margin: 0 0 10px 0;
        }
        
        .page-subtitle {
            color: #7f8c8d;
            font-size: 1.1rem;
            margin: 0;
        }
        
        .stats-section {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-bottom: 40px;
        }
        
        .stat-card {
            background: white;
            border-radius: 12px;
            padding: 25px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.1);
            transition: transform 0.3s ease;
            display: flex;
            align-items: center;
            gap: 20px;
        }
        
        .stat-card:hover {
            transform: translateY(-5px);
        }
        
        .stat-icon {
            width: 60px;
            height: 60px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            color: white;
        }
        
        .stat-icon.admin-stat {
            background: linear-gradient(135deg, #ff6b6b, #ee5a24);
        }
        
        .stat-icon.pt-stat {
            background: linear-gradient(135deg, #4ecdc4, #44a08d);
        }
        
        .stat-icon.staff-stat {
            background: linear-gradient(135deg, #a8e6cf, #7fcdcd);
        }
        
        .stat-icon.patients-stat {
            background: linear-gradient(135deg, #667eea, #764ba2);
        }
        
        .stat-icon.appointments-stat {
            background: linear-gradient(135deg, #f093fb, #f5576c);
        }
        
        .stat-icon.revenue-stat {
            background: linear-gradient(135deg, #4facfe, #00f2fe);
        }
        
        .stat-details h3 {
            font-size: 2rem;
            margin: 0 0 5px 0;
            color: #2c3e50;
        }
        
        .stat-details p {
            margin: 0;
            color: #7f8c8d;
            font-weight: 500;
        }
        
        .charts-section {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
            margin-bottom: 40px;
        }
        
        .chart-card {
            background: white;
            border-radius: 12px;
            padding: 25px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.1);
        }
        
        .chart-title {
            font-size: 1.3rem;
            color: #2c3e50;
            margin: 0 0 20px 0;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        .chart-placeholder {
            height: 300px;
            background: linear-gradient(135deg, #f8f9fa, #e9ecef);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #7f8c8d;
            font-size: 1.1rem;
        }
        
        .reports-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 20px;
        }
        
        .report-card {
            background: white;
            border-radius: 12px;
            padding: 25px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.1);
            transition: transform 0.3s ease;
        }
        
        .report-card:hover {
            transform: translateY(-5px);
        }
        
        .report-title {
            font-size: 1.2rem;
            color: #2c3e50;
            margin: 0 0 15px 0;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        .report-description {
            color: #7f8c8d;
            margin: 0 0 20px 0;
            line-height: 1.6;
        }
        
        .btn-generate {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 10px 20px;
            border: none;
            border-radius: 8px;
            text-decoration: none;
            font-weight: 500;
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }
        
        .btn-generate:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(102, 126, 234, 0.3);
            color: white;
        }

        .btn-generate {
            background: linear-gradient(135deg, #e74c3c, #c0392b);
            color: white;
            padding: 10px 20px;
            border: none;
            border-radius: 8px;
            text-decoration: none;
            font-weight: 500;
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }
        
        .btn-generate:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(231, 76, 60, 0.3);
            color: white;
        }
        
        @media (max-width: 768px) {
            .charts-section {
                grid-template-columns: 1fr;
            }
            
            .stats-section {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <div class="admin-container">
        <a href="/index" class="back-btn">
            <i class="fas fa-arrow-left"></i>
            กลับสู่หน้าหลัก
        </a>
        
        <div class="page-header">
            <h1 class="page-title">
                <i class="fas fa-chart-bar"></i>
                <%= title %>
            </h1>
            <p class="page-subtitle">รายงานและสถิติการใช้งานระบบ</p>
        </div>
        
        <!-- สถิติผู้ใช้ -->
        <div class="stats-section">
            <div class="stat-card" data-delay="0.1">
                <div class="stat-icon admin-stat">
                    <i class="fas fa-user-shield"></i>
                </div>
                <div class="stat-details">
                    <h3><%= stats.usersByRole?.admin || 0 %></h3>
                    <p>ผู้ดูแลระบบ</p>
                </div>
            </div>
            
            <div class="stat-card" data-delay="0.2">
                <div class="stat-icon pt-stat">
                    <i class="fas fa-user-md"></i>
                </div>
                <div class="stat-details">
                    <h3><%= stats.usersByRole?.physical_therapist || 0 %></h3>
                    <p>นักกายภาพบำบัด</p>
                </div>
            </div>
            
            <div class="stat-card" data-delay="0.3">
                <div class="stat-icon staff-stat">
                    <i class="fas fa-user"></i>
                </div>
                <div class="stat-details">
                    <h3><%= stats.usersByRole?.staff || 0 %></h3>
                    <p>เจ้าหน้าที่</p>
                </div>
            </div>
            
            <div class="stat-card" data-delay="0.4">
                <div class="stat-icon patients-stat">
                    <i class="fas fa-users"></i>
                </div>
                <div class="stat-details">
                    <h3><%= stats.totalPatients || 0 %></h3>
                    <p>ผู้ป่วยทั้งหมด</p>
                </div>
            </div>
            
            <div class="stat-card" data-delay="0.5">
                <div class="stat-icon appointments-stat">
                    <i class="fas fa-calendar-check"></i>
                </div>
                <div class="stat-details">
                    <h3><%= stats.todayAppointments || 0 %></h3>
                    <p>นัดหมายวันนี้</p>
                </div>
            </div>
            
            <div class="stat-card" data-delay="0.6">
                <div class="stat-icon revenue-stat">
                    <i class="fas fa-chart-line"></i>
                </div>
                <div class="stat-details">
                    <h3><%= (stats.thisMonthRevenue || 0).toLocaleString() %></h3>
                    <p>รายได้เดือนนี้ (บาท)</p>
                </div>
            </div>
        </div>
        
        <!-- กราฟและแผนภูมิ -->
        <div class="charts-section">
            <div class="chart-card">
                <h2 class="chart-title">
                    <i class="fas fa-chart-pie"></i>
                    สถิติการรักษา
                </h2>
                <div class="chart-placeholder">
                    <i class="fas fa-chart-pie"></i>
                    กราฟสถิติการรักษาจะแสดงที่นี่
                </div>
            </div>
            
            <div class="chart-card">
                <h2 class="chart-title">
                    <i class="fas fa-chart-line"></i>
                    รายได้รายเดือน
                </h2>
                <div class="chart-placeholder">
                    <i class="fas fa-chart-line"></i>
                    กราฟรายได้รายเดือนจะแสดงที่นี่
                </div>
            </div>
        </div>
        
        <!-- รายงานต่างๆ -->
        <div class="reports-grid">
            <div class="report-card">
                <h3 class="report-title">
                    <i class="fas fa-file-medical"></i>
                    รายงานผู้ป่วย
                </h3>
                <p class="report-description">
                    รายงานข้อมูลผู้ป่วยทั้งหมด รวมถึงสถิติการรักษาและประวัติการมาใช้บริการ
                </p>
                <a href="/admin/reports/patients?format=pdf" class="btn-generate" target="_blank">
                    <i class="fas fa-file-pdf"></i>
                    ดาวน์โหลดรายงาน PDF
                </a>
            </div>
            
            <div class="report-card">
                <h3 class="report-title">
                    <i class="fas fa-calendar-alt"></i>
                    รายงานนัดหมาย
                </h3>
                <p class="report-description">
                    รายงานข้อมูลการนัดหมายทั้งหมด รวมถึงสถิติการมาใช้บริการและการยกเลิกนัด
                </p>
                <a href="/admin/reports/appointments?format=pdf" class="btn-generate" target="_blank">
                    <i class="fas fa-file-pdf"></i>
                    ดาวน์โหลดรายงาน PDF
                </a>
            </div>
            
            <div class="report-card">
                <h3 class="report-title">
                    <i class="fas fa-money-bill-wave"></i>
                    รายงานการเงิน
                </h3>
                <p class="report-description">
                    รายงานข้อมูลการเงินทั้งหมด รวมถึงรายได้ ค่าใช้จ่าย และกำไร-ขาดทุน
                </p>
                <a href="/admin/reports/financial?format=pdf" class="btn-generate" target="_blank">
                    <i class="fas fa-file-pdf"></i>
                    ดาวน์โหลดรายงาน PDF
                </a>
            </div>
            
            <div class="report-card">
                <h3 class="report-title">
                    <i class="fas fa-users-cog"></i>
                    รายงานผู้ใช้งาน
                </h3>
                <p class="report-description">
                    รายงานข้อมูลผู้ใช้งานระบบ รวมถึงสถิติการเข้าใช้งานและกิจกรรมต่างๆ
                </p>
                <a href="/admin/reports/users?format=pdf" class="btn-generate" target="_blank">
                    <i class="fas fa-file-pdf"></i>
                    ดาวน์โหลดรายงาน PDF
                </a>
            </div>
        </div>
    </div>
    
    <script>
        // Animation for stat cards
        const observerOptions = {
            threshold: 0.1,
            rootMargin: '0px 0px -50px 0px'
        };
        
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.style.opacity = '1';
                    entry.target.style.transform = 'translateY(0)';
                }
            });
        }, observerOptions);
        
        document.querySelectorAll('.stat-card').forEach(card => {
            card.style.opacity = '0';
            card.style.transform = 'translateY(20px)';
            card.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
            observer.observe(card);
        });

        // ฟังก์ชันสำหรับการดาวน์โหลดรายงาน PDF
        document.querySelectorAll('.btn-generate').forEach(btn => {
            btn.addEventListener('click', async function(e) {
                e.preventDefault();
                
                const originalText = this.innerHTML;
                this.innerHTML = '<i class="fas fa-spinner fa-spin"></i> กำลังสร้าง PDF...';
                this.style.pointerEvents = 'none';
                
                try {
                    // สำหรับ PDF ให้เปิดในหน้าต่างใหม่
                    window.open(this.href, '_blank');
                    
                    // แสดงข้อความสำเร็จ
                    this.innerHTML = '<i class="fas fa-check"></i> กำลังดาวน์โหลด';
                    this.style.background = 'linear-gradient(135deg, #4CAF50, #45a049)';
                    
                    setTimeout(() => {
                        this.innerHTML = originalText;
                        this.style.background = '';
                        this.style.pointerEvents = '';
                    }, 3000);
                } catch (error) {
                    console.error('Error generating PDF:', error);
                    this.innerHTML = '<i class="fas fa-exclamation-triangle"></i> เกิดข้อผิดพลาด';
                    this.style.background = 'linear-gradient(135deg, #f44336, #da190b)';
                    
                    setTimeout(() => {
                        this.innerHTML = originalText;
                        this.style.background = '';
                        this.style.pointerEvents = '';
                    }, 3000);
                }
            });
        });
    </script>
</body>
</html>
