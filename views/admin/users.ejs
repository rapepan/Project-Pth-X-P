<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600;700&family=Sarabun:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
    <div class="admin-container">
        <a href="/index" class="back-btn">
            <i class="fas fa-arrow-left"></i>
            กลับสู่หน้าหลัก
        </a>
        
        <div class="page-header">
            <h1 class="page-title">
                <i class="fas fa-users-cog"></i>
                <%= title %>
            </h1>
            <a href="/admin/users/create" class="btn-add-user">
                <i class="fas fa-user-plus"></i>
                เพิ่มผู้ใช้ใหม่
            </a>
        </div>
        
        <div class="users-table">
            <% if (users && users.length > 0) { %>
                <table class="table">
                    <thead>
                        <tr>
                            <th>ชื่อผู้ใช้</th>
                            <th>ชื่อ-นามสกุล</th>
                            <th>อีเมล</th>
                            <th>ระดับผู้ใช้</th>
                            <th>วันที่สร้าง</th>
                            <th>จัดการ</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% users.forEach(user => { %>
                            <tr>
                                <td>
                                    <strong><%= user.username %></strong>
                                </td>
                                <td><%= user.fullname %></td>
                                <td><%= user.email %></td>
                                <td>
                                    <% if (user.role === 'admin') { %>
                                        <span class="role-badge role-admin">
                                            <i class="fas fa-user-shield"></i>
                                            Admin
                                        </span>
                                    <% } else if (user.role === 'physical_therapist') { %>
                                        <span class="role-badge role-physical-therapist">
                                            <i class="fas fa-user-md"></i>
                                            Physical Therapist
                                        </span>
                                    <% } else { %>
                                        <span class="role-badge role-staff">
                                            <i class="fas fa-user"></i>
                                            Staff
                                        </span>
                                    <% } %>
                                </td>
                                <td>
                                    <%= new Date(user.created_at).toLocaleDateString('th-TH', {
                                        year: 'numeric',
                                        month: 'long',
                                        day: 'numeric'
                                    }) %>
                                </td>
                                <td>
                                    <div class="btn-group">
                                        <a href="/admin/users/<%= user.id %>/edit" class="btn-edit">
                                            <i class="fas fa-edit"></i>
                                            แก้ไข
                                        </a>
                                        <% if (user.id !== currentUser.id) { %>
                                            <form method="POST" action="/admin/users/<%= user.id %>/delete" style="display: inline;" onsubmit="return confirm('คุณแน่ใจหรือไม่ที่จะลบผู้ใช้นี้?')">
                                                <button type="submit" class="btn-delete">
                                                    <i class="fas fa-trash"></i>
                                                    ลบ
                                                </button>
                                            </form>
                                        <% } else { %>
                                            <button class="btn-delete disabled" disabled>
                                                <i class="fas fa-trash"></i>
                                                ลบ
                                            </button>
                                        <% } %>
                                    </div>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            <% } else { %>
                <div class="empty-state">
                    <i class="fas fa-users"></i>
                    <h3>ยังไม่มีผู้ใช้ในระบบ</h3>
                    <p>เริ่มต้นด้วยการเพิ่มผู้ใช้ใหม่</p>
                    <a href="/admin/users/create" class="btn-add-user">
                        <i class="fas fa-user-plus"></i>
                        เพิ่มผู้ใช้ใหม่
                    </a>
                </div>
            <% } %>
        </div>
    </div>
</body>
</html>
