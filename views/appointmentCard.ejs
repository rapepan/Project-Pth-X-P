<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600;700&family=Sarabun:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/appointmentCard.css">
</head>
<body>
    <!-- Print Controls (hidden when printing) -->
    <div class="print-controls no-print">
        <h3>ใบนัดหมาย</h3>
        <p>ตรวจสอบข้อมูลก่อนพิมพ์</p>
        <button class="btn-print" onclick="window.print()">
            <i class="fas fa-print"></i>
            พิมพ์ใบนัดหมาย
        </button>
        <a href="/appointments/<%= appointment.id %>" class="btn-back">
            <i class="fas fa-arrow-left"></i>
            กลับไปรายละเอียด
        </a>
    </div>

    <!-- Appointment Card -->
    <%
        // ประกาศตัวแปรร่วมกันสำหรับทั้งไฟล์
        const thaiMonths = ['มกราคม', 'กุมภาพันธ์', 'มีนาคม', 'เมษายน', 'พฤษภาคม', 'มิถุนายน', 'กรกฎาคม', 'สิงหาคม', 'กันยายน', 'ตุลาคม', 'พฤศจิกายน', 'ธันวาคม'];
        
        // จัดรูปแบบวันที่นัดหมาย
        const appointmentDate = new Date(appointment.appointment_date);
        const day = appointmentDate.getDate();
        const month = thaiMonths[appointmentDate.getMonth()];
        const year = appointmentDate.getFullYear() + 543;
        const formattedDate = `${day} ${month} ${year}`;
        
        // จัดรูปแบบเวลานัดหมาย
        const timeString = appointment.appointment_time;
        const [hours, minutes] = timeString.split(':');
        const formattedTime = `${hours}:${minutes} น.`;
        
        // จัดรูปแบบประเภทนัดหมาย
        const typeTexts = {
            'examination': 'การตรวจร่างกาย',
            'treatment': 'การรักษา',
            'consultation': 'การปรึกษา',
            'follow_up': 'การติดตามผล',
            'other': 'อื่นๆ'
        };
        const formattedType = typeTexts[appointment.appointment_type] || appointment.appointment_type;
        
        // จัดรูปแบบวันที่พิมพ์
        const now = new Date();
        const printDay = now.getDate();
        const printMonth = thaiMonths[now.getMonth()];
        const printYear = now.getFullYear() + 543;
        const printHours = now.getHours().toString().padStart(2, '0');
        const printMinutes = now.getMinutes().toString().padStart(2, '0');
        const printDate = `${printDay} ${printMonth} ${printYear} เวลา ${printHours}:${printMinutes}`;
    %>
    <div class="appointment-card-template">
        <div class="card-header">
            <div class="clinic-name">
                <i class="fas fa-heartbeat"></i>
                คลินิกกายภาพบำบัด
            </div>
            <h2 class="card-title">ใบนัดหมาย</h2>
        </div>
        
        <div class="patient-info">
            <div class="info-row">
                <span class="info-label">ชื่อ-นามสกุล:</span>
                <span class="info-value"><%= appointment.patient_name %></span>
            </div>
            
            <div class="info-row">
                <span class="info-label">เลข HN:</span>
                <span class="info-value"><%= appointment.HN %></span>
            </div>
            
            <div class="info-row">
                <span class="info-label">วันที่นัดหมาย:</span>
                <span class="info-value">
                    <%= formattedDate %>
                </span>
            </div>
            
            <div class="info-row">
                <span class="info-label">เวลานัดหมาย:</span>
                <span class="info-value">
                    <%= formattedTime %>
                </span>
            </div>
            
            <% if (appointment.patient_phone) { %>
            <div class="info-row">
                <span class="info-label">เบอร์โทร:</span>
                <span class="info-value"><%= appointment.patient_phone %></span>
            </div>
            <% } %>
            
            <% if (appointment.notes) { %>
            <div class="info-row">
                <span class="info-label">หมายเหตุ:</span>
                <span class="info-value"><%= appointment.notes %></span>
            </div>
            <% } %>
            
            <div class="info-row">
                <span class="info-label">สร้างโดย:</span>
                <span class="info-value"><%= appointment.created_by_name || 'ไม่ระบุ' %></span>
            </div>
        </div>
        
        <div class="card-footer">
            <div class="footer-note">
                <i class="fas fa-exclamation-triangle"></i>
                กรุณามาก่อนเวลานัด 15 นาที
            </div>
            <div class="footer-note">
                หากไม่สามารถมาตามนัดได้ กรุณาติดต่อล่วงหน้า
            </div>
            <div class="clinic-contact">
                <i class="fas fa-phone"></i>
                โทร: 02-123-4567 | 
                <i class="fas fa-envelope"></i>
                Email: clinic@example.com
            </div>
            <div class="print-date">
                พิมพ์เมื่อ: 
                <%= printDate %>
            </div>
        </div>
    </div>

    <!-- JavaScript for formatting -->
    <script src="/js/appointments.js"></script>
</body>
</html>

