<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600;700&family=Sarabun:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/appointments.css">
</head>
<body>


    <div class="main-container">
        <!-- Page Header -->
        <div class="page-header">
            <div class="header-content">
                <div class="header-title-section">
                    <a href="/appointments" class="back-btn">
                        <i class="fas fa-arrow-left"></i>
                        <span>กลับรายการนัดหมาย</span>
                    </a>
                    <div class="title-info">
                        <h1 class="page-title">
                            <i class="fas fa-calendar-plus"></i>
                            <%= title %>
                        </h1>
                        <p class="page-subtitle">
                            <%= appointment ? 'แก้ไขข้อมูลนัดหมาย' : 'สร้างนัดหมายใหม่สำหรับผู้ป่วย' %>
                        </p>
                    </div>
                </div>
            </div>
            <div class="header-actions">
                <a href="/index" class="btn btn-secondary">
                    <i class="fas fa-home"></i>
                    หน้าหลัก
                </a>
            </div>
        </div>

        <!-- Appointment Form -->
        <div class="appointment-form">
            <div class="form-header">
                <h2>
                    <i class="fas fa-calendar-check"></i>
                    ข้อมูลนัดหมาย
                </h2>
                <p>กรุณากรอกข้อมูลให้ครบถ้วน</p>
            </div>

            <form action="<%= appointment ? `/appointments/${appointment.id}/edit` : '/appointments/create' %>" 
                  method="POST" class="appointment-form-content">
                
                <!-- Patient Information Section -->
                <div class="form-section">
                    <h3 class="section-title">
                        <i class="fas fa-user"></i>
                        ข้อมูลผู้ป่วย
                    </h3>
                    
                    <div class="form-row">
                        <div class="form-group">
                            <label for="HN" class="form-label">เลข HN *</label>
                            <input type="text" id="HN" name="HN" class="form-control" 
                                   value="<%= appointment ? appointment.HN : (patientData ? patientData.HN : '') %>" 
                                   placeholder="กรอกเลข HN เพื่อค้นหาผู้ป่วย" required>
                            <% if (!appointment && !patientData) { %>
                            <small class="form-text">กรุณากรอกเลข HN ของผู้ป่วย</small>
                            <% } %>
                        </div>
                        
                        <div class="form-group">
                            <label for="patient_name" class="form-label">ชื่อ-นามสกุล *</label>
                            <input type="text" id="patient_name" name="patient_name" class="form-control patient-info-field" 
                                   value="<%= appointment ? appointment.patient_name : (patientData ? patientData.fullname : '') %>" 
                                   required>
                        </div>
                    </div>
                    
                    <div class="form-row">
                        <div class="form-group">
                            <label for="patient_phone" class="form-label">เบอร์โทรศัพท์</label>
                            <input type="tel" id="patient_phone" name="patient_phone" class="form-control patient-info-field" 
                                   value="<%= appointment ? appointment.patient_phone : (patientData ? patientData.phone : '') %>">
                        </div>
                    </div>
                    
                    <div class="form-group">
                        <label for="patient_address" class="form-label">ที่อยู่</label>
                        <textarea id="patient_address" name="patient_address" class="form-control patient-info-field" rows="3" 
                                  placeholder="กรอกที่อยู่ผู้ป่วย (ถ้ามี)"><%= appointment ? appointment.patient_address : (patientData ? patientData.address : '') %></textarea>
                    </div>
                </div>

                <!-- Appointment Information Section -->
                <div class="form-section">
                    <h3 class="section-title">
                        <i class="fas fa-calendar-alt"></i>
                        ข้อมูลนัดหมาย
                    </h3>
                    
                    <div class="form-row">
                        <div class="form-group">
                            <label for="appointment_date" class="form-label">วันที่นัดหมาย *</label>
                            <input type="date" id="appointment_date" name="appointment_date" class="form-control" 
                                   value="<%= appointment ? appointment.appointment_date : '' %>" required>
                            <small class="form-text">เลือกวันที่ต้องการนัดหมาย</small>
                        </div>
                        
                        <div class="form-group">
                            <label for="appointment_time" class="form-label">เวลานัดหมาย *</label>
                            <input type="time" id="appointment_time" name="appointment_time" class="form-control" 
                                   value="<%= appointment ? appointment.appointment_time : '' %>" required>
                            <small class="form-text">เวลาทำการ: 08:00 - 17:00 น.</small>
                        </div>
                    </div>
                    
                    <% if (appointment) { %>
                    <div class="form-row">
                        <div class="form-group">
                            <label for="status" class="form-label">สถานะ</label>
                            <select id="status" name="status" class="form-control form-select">
                                <option value="scheduled" <%= appointment.status === 'scheduled' ? 'selected' : '' %>>
                                    รอการยืนยัน
                                </option>
                                <option value="confirmed" <%= appointment.status === 'confirmed' ? 'selected' : '' %>>
                                    ยืนยันแล้ว
                                </option>
                                <option value="completed" <%= appointment.status === 'completed' ? 'selected' : '' %>>
                                    เสร็จสิ้น
                                </option>
                                <option value="cancelled" <%= appointment.status === 'cancelled' ? 'selected' : '' %>>
                                    ยกเลิก
                                </option>
                                <option value="no_show" <%= appointment.status === 'no_show' ? 'selected' : '' %>>
                                    ไม่มาตามนัด
                                </option>
                            </select>
                        </div>
                    </div>
                    <% } %>
                    
                    <div class="form-group">
                        <label for="notes" class="form-label">หมายเหตุ</label>
                        <textarea id="notes" name="notes" class="form-control" rows="4" 
                                  placeholder="กรอกหมายเหตุเพิ่มเติม (ถ้ามี)"><%= appointment ? appointment.notes : '' %></textarea>
                    </div>
                </div>

                <!-- Form Actions -->
                <div class="form-actions">
                    <button type="submit" class="btn-submit">
                        <i class="fas fa-save"></i>
                        <%= appointment ? 'บันทึกการแก้ไข' : 'สร้างนัดหมาย' %>
                    </button>
                    
                    <a href="/appointments" class="btn-cancel">
                        <i class="fas fa-times"></i>
                        ยกเลิก
                    </a>
                </div>
            </form>
        </div>
    </div>


    <!-- Scripts -->
    <script src="/js/appointments.js"></script>
    
    <script>
        // Initialize appointment form functionality
        document.addEventListener('DOMContentLoaded', function() {
            // Set minimum date to today
            const dateInput = document.getElementById('appointment_date');
            if (dateInput) {
                const today = new Date().toISOString().split('T')[0];
                dateInput.setAttribute('min', today);
            }
            
            // Set default time if empty
            const timeInput = document.getElementById('appointment_time');
            if (timeInput && !timeInput.value) {
                const now = new Date();
                const hours = now.getHours().toString().padStart(2, '0');
                const minutes = (Math.ceil(now.getMinutes() / 15) * 15).toString().padStart(2, '0');
                timeInput.value = `${hours}:${minutes}`;
            }

            // Initialize patient search functionality
            initializePatientSearch();
        });

        function initializePatientSearch() {
            const hnInput = document.getElementById('HN');

            if (hnInput) {
                // Auto search when typing (with debounce)
                let searchTimeout;
                hnInput.addEventListener('input', function() {
                    clearTimeout(searchTimeout);
                    searchTimeout = setTimeout(() => {
                        if (this.value.trim().length >= 3) {
                            searchPatients();
                        } else {
                            // Clear patient data if HN is too short
                            clearPatientData();
                        }
                    }, 800); // เพิ่มเวลารอให้มากขึ้น
                });
            }
        }

        async function searchPatients() {
            const hnInput = document.getElementById('HN');
            
            if (!hnInput) return;

            const searchTerm = hnInput.value.trim();
            
            if (searchTerm.length < 3) {
                clearPatientData();
                return;
            }
            
            try {
                const response = await fetch(`/patients/search?q=${encodeURIComponent(searchTerm)}`);
                const patients = await response.json();
                
                if (patients.length > 0) {
                    // Auto-fill patient data
                    const patient = patients[0];
                    selectPatient(patient.HN, patient.fullname, patient.phone || '', patient.address || '');
                } else {
                    // Clear patient data if no results
                    clearPatientData();
                }
            } catch (error) {
                console.error('Error searching patients:', error);
                clearPatientData();
            }
        }
        
        function selectPatient(HN, name, phone, address) {
            document.getElementById('HN').value = HN;
            document.getElementById('patient_name').value = name;
            document.getElementById('patient_phone').value = phone;
            document.getElementById('patient_address').value = address;
            
            // Add readonly behavior to patient info fields
            addReadonlyBehavior();
            
            // Focus on appointment date
            document.getElementById('appointment_date').focus();
        }

        function clearPatientData() {
            document.getElementById('patient_name').value = '';
            document.getElementById('patient_phone').value = '';
            document.getElementById('patient_address').value = '';
            
            // Remove readonly behavior
            removeReadonlyBehavior();
        }

        function addReadonlyBehavior() {
            const patientFields = document.querySelectorAll('.patient-info-field');
            patientFields.forEach(field => {
                field.addEventListener('keydown', preventEditing);
                field.addEventListener('paste', preventEditing);
                field.addEventListener('cut', preventEditing);
                field.addEventListener('input', preventEditing);
            });
        }

        function removeReadonlyBehavior() {
            const patientFields = document.querySelectorAll('.patient-info-field');
            patientFields.forEach(field => {
                field.removeEventListener('keydown', preventEditing);
                field.removeEventListener('paste', preventEditing);
                field.removeEventListener('cut', preventEditing);
                field.removeEventListener('input', preventEditing);
            });
        }

        function preventEditing(e) {
            e.preventDefault();
            e.stopPropagation();
            return false;
        }
    </script>
</body>
</html>

