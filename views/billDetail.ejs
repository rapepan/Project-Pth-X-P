<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>รายละเอียดใบเสร็จ - <%= bill.bill_number %></title>
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background-color: #f8f9fa;
            color: #333;
            line-height: 1.6;
        }
        
        .invoice-container {
            max-width: 800px;
            margin: 0 auto;
            background: white;
            min-height: 100vh;
            padding: 40px;
            box-shadow: 0 0 20px rgba(0,0,0,0.1);
        }
        
        .close-link {
            color: #666;
            text-decoration: none;
            font-size: 14px;
            margin-bottom: 20px;
            display: inline-block;
            transition: color 0.2s ease;
        }
        
        .close-link:hover {
            color: #333;
        }
        
        .paid-status {
            font-size: 24px;
            font-weight: 700;
            color: #2c3e50;
            margin-bottom: 30px;
        }
        
        .section {
            margin-bottom: 30px;
        }
        
        .section-title {
            font-size: 14px;
            font-weight: 600;
            color: #666;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 15px;
        }
        
        .divider {
            height: 1px;
            background-color: #e1e5e9;
            margin: 20px 0;
        }
        
        .info-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 8px;
        }
        
        .info-row {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
        }
        
        .info-label {
            font-weight: 500;
            color: #555;
            min-width: 80px;
        }
        
        .info-value {
            color: #333;
            text-align: right;
            flex: 1;
            margin-left: 20px;
        }
        
        .memo {
            background-color: #f8f9fa;
            padding: 15px;
            border-radius: 8px;
            margin: 15px 0;
            font-style: italic;
            color: #555;
            border-left: 4px solid #3498db;
        }
        
        .payment-address {
            margin-top: 15px;
            padding: 15px;
            background-color: #f8f9fa;
            border-radius: 8px;
            font-family: 'Courier New', monospace;
            font-size: 14px;
            line-height: 1.4;
        }
        
        .payment-address-title {
            font-weight: 600;
            color: #555;
            margin-bottom: 8px;
        }
        
        .items-section {
            margin-bottom: 30px;
        }
        
        .date-range {
            font-weight: 500;
            color: #555;
            margin-bottom: 15px;
        }
        
        .item-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px 0;
            border-bottom: 1px solid #f1f3f4;
        }
        
        .item-row:last-child {
            border-bottom: none;
        }
        
        .item-name {
            font-weight: 500;
            color: #333;
        }
        
        .item-qty {
            font-size: 14px;
            color: #666;
            margin-top: 2px;
        }
        
        .item-price {
            font-weight: 600;
            color: #333;
            font-size: 16px;
        }
        
        .financial-summary {
            background-color: #f8f9fa;
            padding: 20px;
            border-radius: 8px;
        }
        
        .financial-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 8px 0;
        }
        
        .financial-row.total {
            border-top: 2px solid #e1e5e9;
            margin-top: 10px;
            padding-top: 15px;
            font-weight: 700;
            font-size: 18px;
            color: #2c3e50;
        }
        
        .financial-row.paid {
            color: #27ae60;
            font-weight: 600;
        }
        
        .financial-row.remaining {
            color: #e74c3c;
            font-weight: 600;
        }
        
        .financial-label {
            color: #555;
        }
        
        .financial-value {
            font-weight: 600;
            color: #333;
        }
        
        .action-buttons {
            display: flex;
            gap: 1rem;
            margin: 30px 0;
            justify-content: center;
            flex-wrap: wrap;
        }
        
        .btn-back,
        .btn-print {
            background: #3498db;
            color: white;
            border: none;
            padding: 12px 24px;
            border-radius: 8px;
            text-decoration: none;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            transition: all 0.3s ease;
            cursor: pointer;
            font-size: 14px;
        }
        
        .btn-print {
            background: #27ae60;
        }
        
        .btn-back:hover,
        .btn-print:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
        }
        
        .btn-back:hover {
            background: #2980b9;
        }
        
        .btn-print:hover {
            background: #229954;
        }
        
        .footer {
            margin-top: 40px;
            text-align: center;
            color: #666;
            font-size: 14px;
        }
        
        .contact-link {
            color: #3498db;
            text-decoration: none;
        }
        
        .contact-link:hover {
            text-decoration: underline;
        }
        
        .status-badge {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        
        .status-paid {
            background-color: #d4edda;
            color: #155724;
        }
        
        .status-pending {
            background-color: #fff3cd;
            color: #856404;
        }
        
        .status-cancelled {
            background-color: #f8d7da;
            color: #721c24;
        }
        
        @media print {
            body {
                background: white !important;
                font-size: 12px;
                line-height: 1.4;
            }
            
            .invoice-container {
                box-shadow: none !important;
                max-width: none !important;
                margin: 0 !important;
                padding: 15px !important;
            }
            
            .close-link,
            .action-buttons,
            .btn-back,
            .btn-print {
                display: none !important;
            }
            
            .paid-status {
                border: 2px solid #27ae60 !important;
                background: #f8fff8 !important;
            }
            
            .unpaid-status {
                border: 2px solid #e74c3c !important;
                background: #fff8f8 !important;
            }
            
            .section-title {
                font-size: 14px !important;
                margin-bottom: 8px !important;
            }
            
            .info-row {
                margin-bottom: 4px !important;
            }
            
            .item {
                padding: 8px 0 !important;
                border-bottom: 1px solid #ddd !important;
            }
            
            .financial-row {
                padding: 6px 0 !important;
            }
            
            .financial-row.total {
                border-top: 2px solid #333 !important;
                margin-top: 10px !important;
                padding-top: 10px !important;
                font-weight: bold !important;
            }
            
            .divider {
                margin: 15px 0 !important;
                height: 2px !important;
            }
            
            /* ตั้งค่าหน้ากระดาษ */
            @page {
                margin: 1cm;
                size: A4;
            }
            
            /* ซ่อน elements ที่ไม่ต้องการ */
            .header-actions,
            .footer-actions,
            .navigation,
            .sidebar {
                display: none !important;
            }
        }
        
        @media (max-width: 768px) {
            .invoice-container {
                padding: 20px;
            }
            
            .paid-status {
                font-size: 20px;
            }
            
            .info-row {
                flex-direction: column;
                gap: 5px;
            }
            
            .info-value {
                text-align: left;
                margin-left: 0;
            }
        }
    </style>
</head>
<body>
    <div class="invoice-container">
        <!-- Close Link -->
        <a href="javascript:window.close()" class="close-link">
            <i class="fas fa-times"></i> ปิดใบเสร็จ
        </a>
        
        <!-- Summary Section -->
        <div class="section">
            <div class="section-title"></div>
            <div class="info-grid">
                <div class="info-row">
                    <span class="info-label">HN:</span>
                    <span class="info-value"> <%= bill.HN %></span>
                </div>
                <div class="info-row">
                    <span class="info-label">ถึง:</span>
                    <span class="info-value">คุณ <%= bill.patient_name %> (HN: <%= bill.HN %>)</span>
                </div>
                <div class="info-row">
                    <span class="info-label">จาก:</span>
                    <span class="info-value">คลินิกกายภาพบำบัด</span>
                </div>
                <div class="info-row">
                    <span class="info-label">เลขที่:</span>
                    <span class="info-value"><%= bill.bill_number %></span>
                </div>
                <div class="info-row">
                    <span class="info-label">วันที่:</span>
                    <span class="info-value"><%= new Date(bill.bill_date).toLocaleDateString('th-TH', { 
                        year: 'numeric', 
                        month: 'long', 
                        day: 'numeric' 
                    }) %></span>
                </div>
            </div>
        </div>
        
        <div class="divider"></div>
        
        <!-- Items Section -->
        <div class="section items-section">
            <div class="section-title">รายการบริการ</div>
            <div class="date-range">
                <%= new Date(bill.bill_date).toLocaleDateString('th-TH', { 
                    year: 'numeric', 
                    month: 'long', 
                    day: 'numeric' 
                }) %>
            </div>
            
            <% if (serviceItems && serviceItems.length > 0) { %>
                <% serviceItems.forEach(item => { %>
                    <div class="item-row">
                        <div>
                            <div class="item-name"><%= item.service_name %></div>
                            <div class="item-qty">จำนวน <%= item.quantity %> <%= item.unit %></div>
                        </div>
                        <div class="item-price">
                            <%= (parseFloat(item.price) * parseInt(item.quantity)).toLocaleString('th-TH', {minimumFractionDigits: 2}) %> บาท
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <div class="item-row">
                    <div>
                        <div class="item-name">ไม่พบรายการบริการ</div>
                    </div>
                    <div class="item-price">0.00 บาท</div>
                </div>
            <% } %>
        </div>
        
        <div class="divider"></div>
        
        <!-- Financial Summary -->
        <div class="section">
            <div class="section-title">สรุปยอดเงิน</div>
            <div class="financial-summary">
                <div class="financial-row">
                    <span class="financial-label">ยอดรวมก่อนหักส่วนลด:</span>
                    <span class="financial-value"><%= parseFloat(bill.subtotal || 0).toLocaleString('th-TH', {minimumFractionDigits: 2}) %> บาท</span>
                </div>
                
                <% if (bill.discount_amount > 0) { %>
                    <div class="financial-row">
                        <span class="financial-label">ส่วนลด:</span>
                        <span class="financial-value">-<%= parseFloat(bill.discount_amount).toLocaleString('th-TH', {minimumFractionDigits: 2}) %> บาท</span>
                    </div>
                <% } %>
                
                <div class="financial-row total">
                    <span class="financial-label">ยอดรวมทั้งสิ้น:</span>
                    <span class="financial-value"><%= parseFloat(bill.total_amount).toLocaleString('th-TH', {minimumFractionDigits: 2}) %> บาท</span>
                </div>
                
                <% if (bill.payment_status === 'paid') { %>
                    <div class="financial-row paid">
                        <span class="financial-label">จำนวนที่ชำระแล้ว:</span>
                        <span class="financial-value"><%= parseFloat(bill.patient_paid_amount || bill.total_amount).toLocaleString('th-TH', {minimumFractionDigits: 2}) %> บาท</span>
                    </div>
                    
                    <div class="financial-row remaining" style="color: #27ae60;">
                        <span class="financial-label">คงเหลือ:</span>
                        <span class="financial-value">0.00 บาท</span>
                    </div>
                <% } else { %>
                    <div class="financial-row remaining">
                        <span class="financial-label">คงเหลือ:</span>
                        <span class="financial-value"><%= parseFloat(bill.total_amount).toLocaleString('th-TH', {minimumFractionDigits: 2}) %> บาท</span>
                    </div>
                <% } %>
                
                <% if (bill.payment_method) { %>
                    <div class="financial-row">
                        <span class="financial-label">วิธีการชำระเงิน:</span>
                        <span class="financial-value">
                            <% 
                                const paymentMethods = {
                                    'cash': 'เงินสด',
                                    'transfer': 'โอนเงิน',
                                    'card': 'บัตรเครดิต/เดบิต',
                                    'insurance': 'ประกันสุขภาพ'
                                };
                            %>
                            <%= paymentMethods[bill.payment_method] || bill.payment_method %>
                        </span>
                    </div>
                <% } %>
            </div>
        </div>
        
        <!-- Action Buttons -->
        <div class="action-buttons">
            <a href="/billing/<%= bill.HN %>" class="btn-back">
                <i class="fas fa-arrow-left"></i> กลับไปหน้า Billing
            </a>
            <button type="button" class="btn-print" onclick="printBill()">
                <i class="fas fa-print"></i> พิมพ์ใบเสร็จ
            </button>
        </div>
        
        <!-- Footer -->
        <div class="footer">
            <p>มีคำถาม? <a href="tel:02-123-4567" class="contact-link">ติดต่อคลินิกกายภาพบำบัด Tel: 098-999-9999</a></p>
            <p style="margin-top: 10px; font-size: 12px; color: #999;">
                บิลนี้สร้างขึ้นเมื่อ <%= new Date(bill.created_at).toLocaleDateString('th-TH', { 
                    year: 'numeric', 
                    month: 'long', 
                    day: 'numeric',
                    hour: '2-digit',
                    minute: '2-digit'
                }) %>
            </p>
        </div>
    </div>
    
    <script>
        // Print functionality
        function printBill() {
            window.print();
        }
        
        // Add print button if needed
        document.addEventListener('DOMContentLoaded', function() {
            // You can add a print button here if needed
        });
    </script>
</body>
</html>