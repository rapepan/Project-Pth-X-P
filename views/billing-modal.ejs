<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ใบเสร็จ - <%= patientData ? `${patientData.fname} ${patientData.lname}` : 'ไม่ระบุผู้ป่วย' %></title>
    <link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600;700&family=Sarabun:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/billing-modal.css">
</head>
<body>
    <div class="billing-container">
        <% if (fromProcedure && procedureServices && procedureServices.length > 0) { %>
            <!-- Left Section - Payment Confirmation Card -->
            <div class="payment-status-section">
                <div class="brand-header">
                    <div class="brand-logo">PTH-X-P</div>
                    <div class="brand-name">Physical Therapy Clinic</div>
                </div>
                
                <div class="payment-status-card">
                    <div class="success-icon">
                        <i class="fas fa-check"></i>
                    </div>
                    <div class="payment-title">Invoice paid</div>
                    <div class="payment-amount">฿<%= (parseFloat(totalAmount) * 1.07).toFixed(2) %></div>
                    
                    <a href="/patients" class="close-link">
                        <i class="fas fa-times"></i> Close invoice and payment details
                    </a>
                    
                    <div class="payment-details">
                        <div class="detail-row">
                            <span class="detail-label">Invoice number</span>
                            <span class="detail-value" id="billNumber"><%= billNumber || '-' %></span>
                        </div>
                        <div class="detail-row">
                            <span class="detail-label">Payment date</span>
                            <span class="detail-value" id="paymentDate"><%= currentDate || '-' %></span>
                        </div>
                        <div class="detail-row">
                            <span class="detail-label">Payment method</span>
                            <span class="detail-value" id="paymentMethod">ยังไม่ชำระ</span>
                        </div>
                    </div>
                    
                    <div class="payment-actions">
                        <a href="#" class="btn btn-outline" onclick="downloadInvoice()">
                            <i class="fas fa-download"></i> Download invoice
                        </a>
                        <a href="#" class="btn btn-primary" onclick="downloadReceipt()">
                            <i class="fas fa-file-alt"></i> Download receipt
                        </a>
                    </div>
                    
                    <div class="system-info">
                        Powered by PTH-X-P System
                    </div>
                    
                    <div class="footer-links">
                        <a href="#">Terms</a>
                        <a href="#">Privacy</a>
                    </div>
                </div>
            </div>

            <!-- Right Section - Invoice Details -->
            <div class="invoice-section">
                <div class="invoice-close">
                    <a href="/patients">
                        <i class="fas fa-times"></i> Close invoice and payment details
                    </a>
                </div>
                
                <h2 class="invoice-title">Paid on <%= currentDate || new Date().toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></h2>
                
                <div class="invoice-summary">
                    <h3 class="summary-title">Summary</h3>
                    <div class="summary-row">
                        <span class="summary-label">To:</span>
                        <span class="summary-value bold">
                            <%= patientData ? `${patientData.fname} ${patientData.lname}` : 'ไม่ระบุผู้ป่วย' %><br>
                            <small>HN: <%= HN %></small>
                        </span>
                    </div>
                    <div class="summary-row">
                        <span class="summary-label">From:</span>
                        <span class="summary-value">คลินิกกายภาพบำบัด PTH-X-P</span>
                    </div>
                    <div class="summary-row">
                        <span class="summary-label">Invoice:</span>
                        <span class="summary-value">#<%= billNumber || '-' %></span>
                    </div>
                    <div class="summary-row">
                        <span class="summary-label">Memo:</span>
                        <span class="summary-value">ใบเสร็จจากการรักษา</span>
                    </div>
                </div>
                
                <div class="invoice-items">
                    <h3 class="items-title">Items</h3>
                    <div class="items-list">
                        <% procedureServices.forEach(function(service) { %>
                            <div class="item-row">
                                <div class="item-info">
                                    <div class="item-period">
                                        <% 
                                            const now = new Date();
                                            const nextMonth = new Date(now.getFullYear(), now.getMonth() + 1, now.getDate());
                                            const formatDate = (date) => {
                                                const day = date.getDate();
                                                const month = date.toLocaleDateString('en-US', { month: 'short' }).toUpperCase();
                                                const year = date.getFullYear();
                                                return `${month} ${day}, ${year}`;
                                            };
                                        %>
                                        <%= formatDate(now) %> - <%= formatDate(nextMonth) %>
                                    </div>
                                    <div class="item-name"><%= service.service_name %></div>
                                    <div class="item-qty">Qty <%= service.quantity %></div>
                                </div>
                                <div class="item-price">฿<%= parseFloat(service.price).toLocaleString() %></div>
                            </div>
                        <% }); %>
                    </div>
                </div>
                
                <div class="invoice-totals">
                    <div class="total-row">
                        <span class="total-label">Subtotal</span>
                        <span class="total-value">฿<%= parseFloat(totalAmount).toLocaleString() %></span>
                    </div>
                    <div class="total-row">
                        <span class="total-label">Total excluding tax</span>
                        <span class="total-value">฿<%= parseFloat(totalAmount).toLocaleString() %></span>
                    </div>
                    <div class="total-row">
                        <span class="total-label">VAT - Thailand (7%)</span>
                        <span class="total-value">฿<%= (parseFloat(totalAmount) * 0.07).toFixed(2) %></span>
                    </div>
                    <div class="total-row final">
                        <span class="total-label">Total due</span>
                        <span class="total-value">฿<%= (parseFloat(totalAmount) * 1.07).toFixed(2) %></span>
                    </div>
                    <div class="total-row">
                        <span class="total-label">Amount paid</span>
                        <span class="total-value">฿0</span>
                    </div>
                    <div class="total-row">
                        <span class="total-label">Amount remaining</span>
                        <span class="total-value">฿<%= (parseFloat(totalAmount) * 1.07).toFixed(2) %></span>
                    </div>
                </div>
                
                <div class="contact-info">
                    Questions? <a href="mailto:info@pth-x-p.com">Contact PTH-X-P Clinic</a>
                </div>
            </div>
        <% } else { %>
            <!-- Empty state -->
            <div class="empty-state">
                <div class="empty-icon">
                    <i class="fas fa-file-invoice"></i>
                </div>
                <h2>ไม่มีข้อมูลใบเสร็จ</h2>
                <p>กรุณาไปที่หน้า Procedure เพื่อสร้างใบเสร็จ</p>
                <a href="/patients" class="btn btn-primary">กลับไปหน้าผู้ป่วย</a>
            </div>
        <% } %>
    </div>

    <!-- Toast Notifications -->
    <div id="toast" class="toast">
        <i class="fas fa-check-circle"></i>
        <span class="toast-message"></span>
    </div>

    <!-- ข้อมูลที่ส่งมาจาก server -->
    <div id="billingData" 
         data-hn="<%= HN %>"
         data-from-procedure="<%= typeof fromProcedure !== 'undefined' ? fromProcedure : false %>"
         data-procedure-services='<%- JSON.stringify(procedureServices || []) %>'
         data-total-amount="<%= typeof totalAmount !== 'undefined' ? totalAmount : 0 %>"
         data-patient-data='<%- JSON.stringify(patientData || {}) %>'
         data-procedure-id="<%= procedureId || '' %>"
         data-bill-id="<%= bills && bills.length > 0 ? bills[0].id : '' %>"
         style="display: none;">
    </div>

    <!-- Hidden input สำหรับเก็บ bill ID -->
    <input type="hidden" id="updateBillId" value="<%= bills && bills.length > 0 ? bills[0].id : '' %>">

    <script>
        // ข้อมูลจาก server
        const billingDataElement = document.getElementById('billingData');
        const billingData = {
            HN: billingDataElement.dataset.hn,
            fromProcedure: billingDataElement.dataset.fromProcedure === 'true',
            procedureServices: JSON.parse(billingDataElement.dataset.procedureServices),
            totalAmount: parseFloat(billingDataElement.dataset.totalAmount) || 0,
            patientData: JSON.parse(billingDataElement.dataset.patientData),
            procedureId: billingDataElement.dataset.procedureId
        };

        // ฟังก์ชันสร้างใบเสร็จ
        function createBill() {
            const form = document.getElementById('createBillForm');
            if (!form) {
                console.error('Form not found');
                return;
            }

            const submitBtn = document.querySelector('button[type="submit"]');
            if (submitBtn) {
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> กำลังสร้าง...';
            }

            const formData = new FormData();
            formData.append('serviceItems', JSON.stringify(billingData.procedureServices));
            formData.append('procedureId', billingData.procedureId);
            formData.append('totalAmount', billingData.totalAmount);
            formData.append('paymentStatus', 'pending');
            formData.append('paymentMethod', 'ยังไม่ได้ชำระเงิน');
            formData.append('notes', 'ใบเสร็จจากหัตถการ - สร้างอัตโนมัติจากระบบ');

            fetch(`/billing/${billingData.HN}/create`, {
                method: 'POST',
                body: formData
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    updateBillInfo(data.billId, data.billNumber);
                    updateBillUI(data.billData);
                    showSuccessMessage(data.message || 'สร้างใบเสร็จเรียบร้อย');
                } else {
                    showErrorMessage(data.error || 'เกิดข้อผิดพลาดในการสร้างใบเสร็จ');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                showErrorMessage('เกิดข้อผิดพลาดในการเชื่อมต่อ');
            })
            .finally(() => {
                if (submitBtn) {
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = '<i class="fas fa-check"></i> สร้างใบเสร็จเรียบร้อย';
                }
            });
        }

        // อัปเดตข้อมูลใบเสร็จเมื่อสร้างเสร็จ
        function updateBillInfo(billId, billNumber) {
            document.getElementById('billNumber').textContent = billNumber;
            const today = new Date().toLocaleDateString('th-TH');
            document.getElementById('paymentDate').textContent = today;
            
            // อัปเดต bill ID เพื่อให้สามารถดาวน์โหลดได้
            if (billId) {
                const updateBillIdInput = document.getElementById('updateBillId');
                if (updateBillIdInput) {
                    updateBillIdInput.value = billId;
                }
            }
        }

        // อัปเดต UI หลังสร้างใบเสร็จเสร็จ
        function updateBillUI(billData) {
            if (billData.paymentStatus === 'paid') {
                document.getElementById('paymentMethod').textContent = billData.paymentMethod || 'ชำระแล้ว';
            }
        }

        // แสดงข้อความสำเร็จ
        function showSuccessMessage(message) {
            const toast = document.getElementById('toast');
            toast.className = 'toast success show';
            toast.querySelector('.toast-message').textContent = message;
            setTimeout(() => {
                toast.classList.remove('show');
            }, 3000);
        }

        // แสดงข้อความผิดพลาด
        function showErrorMessage(message) {
            const toast = document.getElementById('toast');
            toast.className = 'toast error show';
            toast.querySelector('.toast i').className = 'fas fa-exclamation-circle';
            toast.querySelector('.toast-message').textContent = message;
            setTimeout(() => {
                toast.classList.remove('show');
            }, 3000);
        }

        // ดาวน์โหลดใบแจ้งหนี้
        function downloadInvoice() {
            const billId = document.getElementById('updateBillId')?.value;
            if (!billId) {
                showErrorMessage('ไม่พบข้อมูลใบเสร็จ กรุณาสร้างใบเสร็จก่อน');
                return;
            }
            window.open(`/billing/${billId}/download/invoice`, '_blank');
        }

        // ดาวน์โหลดใบเสร็จ
        function downloadReceipt() {
            const billId = document.getElementById('updateBillId')?.value;
            if (!billId) {
                showErrorMessage('ไม่พบข้อมูลใบเสร็จ กรุณาสร้างใบเสร็จก่อน');
                return;
            }
            window.open(`/billing/${billId}/download/receipt`, '_blank');
        }

        // เมื่อโหลดหน้าเสร็จ
        document.addEventListener('DOMContentLoaded', function() {
            const urlParams = new URLSearchParams(window.location.search);
            const billId = urlParams.get('billId');
            const billNumber = urlParams.get('billNumber');
            
            if (billId && billNumber) {
                updateBillInfo(billId, billNumber);
            } else if (billingData.fromProcedure && billingData.procedureServices.length > 0) {
                setTimeout(createBill, 1000);
            }
        });

        // ฟังก์ชันสำหรับอัปเดต UI เมื่อได้รับข้อมูลจาก server
        window.updateBillingUI = function(billData) {
            if (billData.billNumber) {
                updateBillInfo(billData.id, billData.billNumber);
            }
            
            if (billData.paymentStatus === 'paid') {
                updateBillUI(billData);
            }
        };
    </script>
</body>
</html>
