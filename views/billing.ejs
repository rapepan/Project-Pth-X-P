<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    
    <!-- Google Fonts สำหรับฟอนต์ไทย -->
    <link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600;700&family=Sarabun:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Font Awesome สำหรับไอคอน -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- CSS ของเรา -->
    <link rel="stylesheet" href="/css/billing.css">
    
</head>
<body>
    <header class="header">
        <div class="header-content">
            <h1>
                <i class="fas fa-file-invoice-dollar"></i>
                <%= title %>
            </h1>
            <div class="user-info">
                <span><%= user.fullname || user.username %></span>
            </div>
        </div>
    </header>

    <nav>
        <a href="/index"><i class="fas fa-home"></i> หน้าหลัก</a>
        <a href="/examinationroom/<%= HN %>"><i class="fas fa-stethoscope"></i> ห้องตรวจ</a>
        <% if (HN) { %>
            <% if (user.role !== 'staff') { %>
                <a href="/procedure/<%= HN %>"><i class="fas fa-hand-holding-medical"></i> หัตถการ</a>
            <% } %>
            <a href="/billing/<%= HN %>" class="active"><i class="fas fa-file-invoice-dollar"></i> สรุปค่าใช้จ่าย</a>
        <% } else { %>
        <% } %>
    </nav>

    <div class="main-container">
        <!-- Alert Messages -->
        <% if (success) { %>
            <div class="alert alert-success">
                <i class="fas fa-check-circle"></i>
                <%= success %>
            </div>
        <% } %>
        
        <% if (error) { %>
            <div class="alert alert-error">
                <i class="fas fa-exclamation-triangle"></i>
                <%= error %>
            </div>
        <% } %>

        <!-- Patient Info Section -->
        <div class="patient-info-section">
            <div class="patient-info-card">
                <div class="patient-header">
                    <h2 class="patient-title">
                        <i class="fas fa-user"></i> ข้อมูลผู้ป่วย
                    </h2>
                </div>
                <div class="patient-details">
                    <div class="patient-field">
                        <label>หมายเลขผู้ป่วย (HN):</label>
                        <span class="patient-value"><%= HN %></span>
                    </div>
                    <div class="patient-field">
                        <label>ชื่อ-นามสกุล:</label>
                        <span class="patient-value"><%= patientName %></span>
                    </div>
                    <div class="patient-field">
                        <label>วันที่ทำหัตถการ:</label>
                        <span class="patient-value">
                            <% if (billingDate) { %>
                                <%= new Date(billingDate).toLocaleDateString('th-TH') %>
                            <% } else if (procedureData) { %>
                                <%= new Date(procedureData.procedure_date).toLocaleDateString('th-TH') %>
                            <% } %>
                        </span>
                    </div>
                    <% if (allProceduresData && allProceduresData.length > 0) { %>
                        <div class="patient-field">
                            <label>จำนวนหัตถการทั้งหมด:</label>
                            <span class="patient-value"><%= allProceduresData.length %> รายการ</span>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>

        <!-- No Procedures Message -->
        <% if (!hasProcedures || !selectedServices || selectedServices.length === 0) { %>
            <div class="no-procedures-section">
                <div class="no-procedures-card">
                    <div class="no-procedures-icon">
                        <i class="fas fa-exclamation-triangle"></i>
                    </div>
                    <div class="no-procedures-content">
                        <h3 class="no-procedures-title">ไม่พบข้อมูลหัตถการ</h3>
                        <p class="no-procedures-message">
                            ไม่พบข้อมูลหัตถการสำหรับผู้ป่วย HN: <%= HN %> ในวันที่ <%= new Date(billingDate).toLocaleDateString('th-TH') %>
                        </p>
                        <% if (user.role !== 'staff') { %>
                            <div class="no-procedures-actions">
                                <a href="/procedure/<%= HN %>" class="btn-create-procedure">
                                    <i class="fas fa-plus"></i> สร้างหัตถการใหม่
                                </a>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        <% } else { %>
            <!-- Services Selection Section -->
            <% if (selectedServices && selectedServices.length > 0) { %>
                <div class="services-section">
                <div class="section-header">
                    <h2 class="section-title">
                        <i class="fas fa-list-alt"></i> บริการที่เลือก
                    </h2>
                </div>
                
                <form action="/billing/<%= HN %>" method="POST" id="billingForm">
                    <div class="services-table-container">
                        <table class="services-table">
                            <thead>
                                <tr>
                                    <th>รหัสบริการ</th>
                                    <th>ชื่อบริการ</th>
                                    <th>ราคา (บาท)</th>
                                    <th>จำนวน</th>
                                    <th>หน่วย</th>
                                    <th>รวม (บาท)</th>
                                </tr>
                            </thead>
                            <tbody id="servicesTableBody">
                                <% selectedServices.forEach((service, index) => { %>
                                    <tr class="service-row" data-service-id="<%= service.id || index %>">
                                        <td class="service-code"><%= service.service_code %></td>
                                        <td class="service-name">
                                            <strong><%= service.service_name %></strong>
                                            <% if (service.category) { %>
                                                <br><small class="service-category"><%= service.category %></small>
                                            <% } %>
                                        </td>
                                        <td class="service-price">
                                            <span class="price-display"><%= parseFloat(service.price).toLocaleString('th-TH', {minimumFractionDigits: 2}) %></span>
                                        </td>
                                        <td class="service-quantity">
                                            <input type="number" 
                                                   name="quantity_<%= index %>" 
                                                   value="<%= service.quantity || 1 %>" 
                                                   min="1" 
                                                   max="999" 
                                                   class="quantity-input"
                                                   data-price="<%= service.price %>"
                                                   data-index="<%= index %>"
                                                   onchange="updateServiceTotal(this)">
                                        </td>
                                        <td class="service-unit"><%= service.unit %></td>
                                        <td class="service-total">
                                            <span class="total-display" id="total_<%= index %>">
                                                <%= (parseFloat(service.price) * parseInt(service.quantity || 1)).toLocaleString('th-TH', {minimumFractionDigits: 2}) %>
                                            </span>
                                        </td>
                                    </tr>
                                <% }); %>
                            </tbody>
                            <tfoot>
                                <tr class="subtotal-row">
                                    <td colspan="5" class="subtotal-label">ยอดรวมก่อนหักส่วนลด:</td>
                                    <td class="subtotal-amount" id="subtotalAmount">
                                        <%= selectedServices.reduce((sum, service) => sum + (parseFloat(service.price) * parseInt(service.quantity || 1)), 0).toLocaleString('th-TH', {minimumFractionDigits: 2}) %>
                                    </td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>

                    <!-- Discount Section -->
                    <div class="discount-section">
                        <h3 class="discount-title">
                            <i class="fas fa-percentage"></i> ส่วนลด
                        </h3>
                        <div class="discount-controls">
                            <div class="discount-type-group">
                                <label class="discount-type-label">ประเภทส่วนลด:</label>
                                <select name="discountType" id="discountType" class="discount-select" onchange="updateDiscountCalculation()">
                                    <option value="none">ไม่มีส่วนลด</option>
                                    <option value="percentage">เปอร์เซ็นต์</option>
                                    <option value="fixed">จำนวนเงินคงที่</option>
                                </select>
                            </div>
                            <div class="discount-amount-group">
                                <label class="discount-amount-label">จำนวนส่วนลด:</label>
                                <input type="number" 
                                       name="discountAmount" 
                                       id="discountAmount" 
                                       value="0" 
                                       min="0" 
                                       step="0.01"
                                       class="discount-input"
                                       onchange="updateDiscountCalculation()"
                                       disabled>
                            </div>
                            <div class="discount-reason-group">
                                <label class="discount-reason-label">เหตุผล:</label>
                                <input type="text" 
                                       name="discountReason" 
                                       id="discountReason"
                                       placeholder="ระบุเหตุผลส่วนลด"
                                       class="discount-input"
                                       disabled>
                            </div>
                        </div>
                    </div>


                    <!-- Total Section -->
                    <div class="total-section">
                        <div class="total-card">
                            <h3 class="total-title">
                                <i class="fas fa-receipt"></i> สรุปยอดเงิน
                            </h3>
                            <div class="total-breakdown">
                                <div class="total-line">
                                    <span class="total-label">ยอดรวมก่อนหักส่วนลด:</span>
                                    <span class="total-value" id="subtotalDisplay">
                                        <%= selectedServices.reduce((sum, service) => sum + (parseFloat(service.price) * parseInt(service.quantity || 1)), 0).toLocaleString('th-TH', {minimumFractionDigits: 2}) %>
                                    </span>
                                </div>
                                <div class="total-line discount-line" id="discountLine" style="display: none;">
                                    <span class="total-label">ส่วนลด:</span>
                                    <span class="total-value discount-value" id="discountDisplay">0.00</span>
                                </div>
                                <div class="total-line final-total">
                                    <span class="total-label"><strong>ยอดเงินรวมทั้งสิ้น:</strong></span>
                                    <span class="total-value final-total-value" id="finalTotalDisplay">
                                        <%= selectedServices.reduce((sum, service) => sum + (parseFloat(service.price) * parseInt(service.quantity || 1)), 0).toLocaleString('th-TH', {minimumFractionDigits: 2}) %>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>

                     <!-- Payment Method Section -->
                     <div class="payment-section">
                         <h3 class="payment-title">
                             <i class="fas fa-credit-card"></i> วิธีการชำระเงิน
                         </h3>
                         <div class="payment-controls">
                            <div class="payment-method-group">
                                <label class="payment-method-label">วิธีการชำระเงิน:</label>
                                <select name="paymentMethod" id="paymentMethod" class="payment-select">
                                    <option value="transfer">โอนเงิน</option>
                                    <option value="cash">เงินสด</option>
                                    <option value="card">บัตรเครดิต/เดบิต</option>
                                    <option value="insurance">ประกันสุขภาพ</option>
                                </select>
                            </div>
                            
                             <div class="insurance-type-group">
                                 <label class="insurance-type-label">ประเภทประกัน:</label>
                                 <select name="insuranceType" class="insurance-select">
                                     <option value="none">ไม่มีประกัน</option>
                                     <option value="social_security">ประกันสังคม</option>
                                     <option value="private">ประกันเอกชน</option>
                                     <option value="government">ประกันข้าราชการ</option>
                                 </select>
                             </div>
                             <div class="amount-received-group" id="amountReceivedGroup" style="display: none;">
                                 <label class="amount-received-label">จำนวนเงินที่รับ:</label>
                                 <input type="number" 
                                        name="amountReceived" 
                                        id="amountReceived" 
                                        value="0" 
                                        min="0" 
                                        step="0.01"
                                        class="amount-received-input"
                                        placeholder="0.00">
                             </div>
                             <div class="change-amount-group" id="changeGroup" style="display: none;">
                                 <label class="change-amount-label">เงินทอน:</label>
                                 <input type="number" 
                                        id="changeAmount" 
                                        value="0" 
                                        step="0.01"
                                        class="change-amount-input"
                                        readonly>
                             </div>
                         </div>
                         
                         <!-- Payment Action Button -->
                         <div class="payment-action">
                             <button type="button" class="btn-payment" id="paymentBtn" onclick="processPayment()">
                                 <i class="fas fa-money-bill-wave"></i>
                                 <span class="btn-text">ยืนยันการชำระเงิน</span>
                                 <span class="btn-loading" style="display: none;">
                                     <i class="fas fa-spinner fa-spin"></i>
                                     กำลังประมวลผล...
                                 </span>
                             </button>
                         </div>
                     </div>

                    <!-- Notes Section -->
                    <div class="notes-section">
                        <h3 class="notes-title">
                            <i class="fas fa-sticky-note"></i> หมายเหตุ
                        </h3>
                        <textarea name="notes" 
                                  class="notes-textarea" 
                                  placeholder="หมายเหตุเพิ่มเติม (ถ้ามี)"
                                  rows="3"></textarea>
                    </div>

                    <!-- Hidden inputs for selected services -->
                    <input type="hidden" name="selectedServices" id="selectedServicesInput" value="<%= JSON.stringify(selectedServices) %>">
                    
                    <!-- Hidden input for created by -->
                    <input type="hidden" name="createdBy" value="<%= user ? user.fullname || user.username : '' %>">

                     <!-- Payment Status Section -->
                     <div class="payment-status-section" id="paymentStatusSection" style="display: none;">
                         <div class="payment-status-card">
                             <div class="payment-status-icon">
                                 <i class="fas fa-check-circle"></i>
                             </div>
                             <div class="payment-status-content">
                                 <h3 class="payment-status-title">ชำระเงินเรียบร้อยแล้ว</h3>
                                 <p class="payment-status-message">
                                     วิธีการชำระเงิน: <span id="paymentMethodDisplay"></span><br>
                                     <span id="amountReceivedDisplay"></span>
                                     <span id="changeDisplay"></span>
                                 </p>
                             </div>
                         </div>
                     </div>

                     <!-- Action Buttons -->
                     <div class="action-buttons">
                         <button type="button" class="btn-billing secondary" onclick="window.history.back()">
                             <i class="fas fa-arrow-left"></i> กลับ
                         </button>
                         <button type="submit" class="btn-billing primary" id="createBillBtn" disabled>
                             <i class="fas fa-file-invoice"></i> สร้างใบเสร็จ
                         </button>
                     </div>
                     
                     <!-- Success Message with Bill Link -->
                     <% if (success && success.includes('สร้างใบเสร็จเรียบร้อยแล้ว')) { %>
                         <div class="success-bill-section">
                             <div class="success-bill-card">
                                 <div class="success-bill-icon">
                                     <i class="fas fa-check-circle"></i>
                                 </div>
                                 <div class="success-bill-content">
                                     <!-- <h3 class="success-bill-title">สร้างใบเสร็จเรียบร้อยแล้ว!</h3> -->
                                     <p class="success-bill-message">ใบเสร็จของคุณพร้อมใช้งานแล้ว</p>
                                     <div class="success-bill-actions">
                                         <a href="#" class="btn-view-bill" id="viewBillBtn">
                                             <i class="fas fa-eye"></i> ดูใบเสร็จ
                                         </a>
                                         <button type="button" class="btn-print-bill" onclick="printBill()">
                                             <i class="fas fa-print"></i> พิมพ์
                                         </button>
                                     </div>
                                 </div>
                             </div>
                         </div>
                     <% } %>
                </form>
            </div>
            <% } else { %>
                <!-- No Services Selected -->
            <div class="no-services-section">
                <div class="no-services-card">
                    <div class="no-services-icon">
                        <i class="fas fa-exclamation-triangle"></i>
                    </div>
                    <h3 class="no-services-title">ไม่พบบริการที่เลือก</h3>
                    <p class="no-services-text">
                        กรุณาไปทำหัตถการก่อนเพื่อเลือกบริการที่ต้องการ
                    </p>
                    <% if (user.role !== 'staff') { %>
                        <div class="no-services-actions">
                            <a href="/procedure/<%= HN %>" class="btn-billing primary">
                                <i class="fas fa-hand-holding-medical"></i> ไปทำหัตถการ
                            </a>
                        </div>
                    <% } %>
                </div>
            </div>
            <% } %>
        <% } %>
    </div>

    <!-- JavaScript -->
    <script src="/js/notifications.js"></script>
    <script src="/js/billing.js"></script>
</body>
</html>
