<!DOCTYPE html>
<html lang="th">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600;700&family=Sarabun:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/index.css">

</head>

<body>
    <!-- Sticky Header -->
    <header class="sticky-header">
        <div class="header-content">
            <div class="logo-section">
                <h1>
                    <i class="fas fa-heartbeat"></i>
                    <%= title %>
                </h1>
            </div>
            <div class="header-actions">
                <a href="/profile" class="profile-btn">
                    <i class="fas fa-user-cog"></i>
                    <span>จัดการโปรไฟล์</span>
                </a>
                <a href="/logout" class="logout-btn">
                    <i class="fas fa-sign-out-alt"></i>
                    <span>ออกจากระบบ</span>
                </a>
            </div>
        </div>
    </header>

    <div class="main-container">
        <!-- Hero Welcome Section -->
        <div class="hero-section">
            <div>
                <h2 class="hero-title">ยินดีต้อนรับคุณ <%= user.fullname || user.username %></h2>
                <p class="hero-subtitle">สู่ระบบบริหารจัดการคลินิกกายภาพบำบัด</p>
                <div class="hero-decoration">
                    <div class="decoration-circle circle-1"></div>
                    <div class="decoration-circle circle-2"></div>
                    <div class="decoration-circle circle-3"></div>
                </div>
            </div>
        </div>

        <!-- Stats Section -->
        <div class="stats-section">
            <div class="stat-card" data-delay="0.1">
                <div class="stat-icon new-patients-stat">
                    <i class="fas fa-user-plus"></i>
                </div>
                <div class="stat-details">
                    <h3 class="stat-number"><%= stats.thisMonthNewPatients || 0 %></h3>
                    <p class="stat-label">ผู้ป่วยใหม่เดือนนี้</p>
                </div>
            </div>
            <div class="stat-card" data-delay="0.2">
                <div class="stat-icon patients-stat">
                    <i class="fas fa-users"></i>
                </div>
                <div class="stat-details">
                    <h3 class="stat-number"><%= stats.totalPatients || 0 %></h3>
                    <p class="stat-label">ผู้ป่วยทั้งหมด</p>
                </div>
            </div>
            <div class="stat-card" data-delay="0.3">
                <div class="stat-icon appointments-stat">
                    <i class="fas fa-calendar-check"></i>
                </div>
                <div class="stat-details">
                    <h3 class="stat-number"><%= stats.todayAppointments || 0 %></h3>
                    <p class="stat-label">นัดหมายวันนี้</p>
                </div>
            </div>
        </div>

        <!-- Additional Stats Section - แสดงเฉพาะ Admin -->
        <% if (userRole === 'admin') { %>
        <div class="stats-section">
            <div class="stat-card" data-delay="0.4">
                <div class="stat-icon revenue-stat">
                    <i class="fas fa-chart-line"></i>
                </div>
                <div class="stat-details">
                    <h3 class="stat-number"><%= (stats.thisMonthRevenue || 0).toLocaleString() %></h3>
                    <p class="stat-label">รายได้เดือนนี้ (บาท)</p>
                </div>
            </div>
            <div class="stat-card" data-delay="0.5">
                <div class="stat-icon billing-stat">
                    <i class="fas fa-receipt"></i>
                </div>
                <div class="stat-details">
                    <h3 class="stat-number"><%= stats.totalBilling || 0 %></h3>
                    <p class="stat-label">ใบเสร็จทั้งหมด</p>
                </div>
            </div>
            <div class="stat-card" data-delay="0.6">
                <div class="stat-icon treatments-stat">
                    <i class="fas fa-heartbeat"></i>
                </div>
                <div class="stat-details">
                    <h3 class="stat-number"><%= stats.thisMonthExaminations || 0 %></h3>
                    <p class="stat-label">การรักษาเดือนนี้</p>
                </div>
            </div>
        </div>
        <% } %>

        <!-- Monthly Revenue Chart Section - แสดงเฉพาะ Admin -->
        <% if (userRole === 'admin') { %>
        <div class="monthly-revenue-section">
            <div class="section-header">
                <h2 class="section-title">
                    <i class="fas fa-chart-line"></i>
                    รายได้รายเดือน (12 เดือนล่าสุด)
                </h2>
                <p class="section-subtitle">รายได้จากการชำระบิลแล้ว</p>
            </div>
            
            <div class="revenue-chart-container">
                <div class="revenue-grid">
                    <% 
                    const months = ['ม.ค.', 'ก.พ.', 'มี.ค.', 'เม.ย.', 'พ.ค.', 'มิ.ย.', 
                                   'ก.ค.', 'ส.ค.', 'ก.ย.', 'ต.ค.', 'พ.ย.', 'ธ.ค.'];
                    const currentYear = new Date().getFullYear();
                    const currentMonth = new Date().getMonth();
                    
                    // สร้างข้อมูล 12 เดือนล่าสุด
                    const monthlyData = [];
                    for (let i = 11; i >= 0; i--) {
                        const date = new Date(currentYear, currentMonth - i, 1);
                        const monthKey = `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, '0')}`;
                        const revenue = stats.monthlyRevenue.find(item => item.month === monthKey);
                        monthlyData.push({
                            month: monthKey,
                            monthName: months[date.getMonth()],
                            year: date.getFullYear(),
                            revenue: revenue ? parseFloat(revenue.revenue) : 0
                        });
                    }
                    
                    monthlyData.forEach((data, index) => {
                        const maxRevenue = Math.max(...monthlyData.map(d => d.revenue));
                        const height = maxRevenue > 0 ? (data.revenue / maxRevenue) * 100 : 0;
                        const heightPercent = Math.round(height);
                    %>
                    <div class="revenue-month-item" data-delay="<%= 0.7 + (index * 0.1) %>">
                        <div class="revenue-bar-container">
                            <div class="revenue-bar" style="--bar-height: <%= heightPercent %>%" 
                                 title="<%= data.monthName %> <%= data.year %>: <%= data.revenue.toLocaleString() %> บาท">
                                <div class="revenue-amount"><%= data.revenue.toLocaleString() %></div>
                            </div>
                        </div>
                        <div class="month-label">
                            <span class="month-name"><%= data.monthName %></span>
                            <span class="year-name"><%= data.year %></span>
                        </div>
                    </div>
                    <% }); %>
                </div>
                
                <% if (monthlyData.some(data => data.revenue > 0)) { %>
                <div class="revenue-summary">
                    <div class="summary-item">
                        <i class="fas fa-calculator"></i>
                        <span class="summary-label">รวมรายได้ 12 เดือน:</span>
                        <span class="summary-value">
                            <%= monthlyData.reduce((sum, data) => sum + data.revenue, 0).toLocaleString() %> บาท
                        </span>
                    </div>
                    <div class="summary-item">
                        <i class="fas fa-chart-line"></i>
                        <span class="summary-label">รายได้เฉลี่ยต่อเดือน:</span>
                        <span class="summary-value">
                            <%= Math.round(monthlyData.reduce((sum, data) => sum + data.revenue, 0) / 12).toLocaleString() %> บาท
                        </span>
                    </div>
                </div>
                <% } else { %>
                <div class="no-revenue-message">
                    <div class="no-revenue-icon">
                        <i class="fas fa-chart-line"></i>
                    </div>
                    <h3>ยังไม่มีข้อมูลรายได้</h3>
                    <p>เมื่อมีการชำระบิลแล้ว ข้อมูลรายได้จะแสดงที่นี่</p>
                </div>
                <% } %>
            </div>
        </div>
        <% } %>

        <!-- Menu Section Header -->
        <div class="section-header">
            <h2 class="section-title">
                <i class="fas fa-th-large"></i>
                เมนูหลัก
            </h2>
            <p class="section-subtitle">เลือกเมนูด้านล่างเพื่อเริ่มใช้งาน</p>
        </div>

        <!-- Menu Grid with Enhanced Cards -->
        <div class="menu-grid">
            <!-- ลงทะเบียนผู้ป่วยใหม่ -->
            <div class="menu-card patients-card" data-delay="0.1" onclick="window.location.href='/patients/add'">
                <div class="card-decoration"></div>
                <div class="icon-wrapper">
                    <i class="fas fa-user-plus"></i>
                </div>
                <div class="card-content">
                    <h3>ลงทะเบียนผู้ป่วยใหม่</h3>
                    <p>เพิ่มข้อมูลผู้ป่วยใหม่เข้าสู่ระบบ พร้อมบันทึกข้อมูลส่วนตัวและประวัติการรักษา</p>
                </div>
                <a href="/patients/add" class="btn-action">
                    <span>เริ่มลงทะเบียน</span>
                    <i class="fas fa-arrow-right"></i>
                </a>
            </div>

            <!-- ค้นหาข้อมูลผู้ป่วย -->
            <div class="menu-card search-card" data-delay="0.2" onclick="window.location.href='/patients'">
                <div class="card-decoration"></div>
                <div class="icon-wrapper">
                    <i class="fas fa-search"></i>
                </div>
                <div class="card-content">
                    <h3>ค้นหาข้อมูลผู้ป่วย</h3>
                    <p>ค้นหาและจัดการข้อมูลผู้ป่วย ดูรายละเอียด และแก้ไขข้อมูลที่จำเป็น</p>
                </div>
                <a href="/patients" class="btn-action">
                    <span>ค้นหาผู้ป่วย</span>
                    <i class="fas fa-arrow-right"></i>
                </a>
            </div>

            <!-- ระบบนัดหมาย -->
            <div class="menu-card appointments-card" data-delay="0.4" onclick="window.location.href='/appointments'">
                <div class="card-decoration"></div>
                <div class="icon-wrapper">
                    <i class="fas fa-calendar-alt"></i>
                </div>
                <div class="card-content">
                    <h3>ระบบนัดหมาย</h3>
                    <p>จัดการนัดหมายผู้ป่วย สร้างใบนัดหมาย และติดตามสถานะการนัดหมาย</p>
                </div>
                <a href="/appointments" class="btn-action">
                    <span>จัดการนัดหมาย</span>
                    <i class="fas fa-arrow-right"></i>
                </a>
            </div>


            <!-- เมนูเฉพาะ Admin -->
            <% if (userRole === 'admin') { %>
            <!-- จัดการผู้ใช้ -->
            <div class="menu-card admin-card" data-delay="1.0" onclick="window.location.href='/admin/users'">
                <div class="card-decoration"></div>
                <div class="icon-wrapper">
                    <i class="fas fa-users-cog"></i>
                </div>
                <div class="card-content">
                    <h3>จัดการผู้ใช้</h3>
                    <p>เพิ่ม แก้ไข และลบผู้ใช้ในระบบ จัดการสิทธิ์การเข้าถึง</p>
                </div>
                <a href="/admin/users" class="btn-action">
                    <span>จัดการผู้ใช้</span>
                    <i class="fas fa-arrow-right"></i>
                </a>
            </div>

            <!-- รายงานและสถิติ -->
            <div class="menu-card reports-card" data-delay="1.1" onclick="window.location.href='/admin/reports'">
                <div class="card-decoration"></div>
                <div class="icon-wrapper">
                    <i class="fas fa-chart-bar"></i>
                </div>
                <div class="card-content">
                    <h3>รายงานและสถิติ</h3>
                    <p>ดูรายงานรายเดือน สถิติการรักษา และข้อมูลการเงิน</p>
                </div>
                <a href="/admin/reports" class="btn-action">
                    <span>ดูรายงาน</span>
                    <i class="fas fa-arrow-right"></i>
                </a>
            </div>
            <% } %>

        </div>

        <!-- Info Footer Section -->
        <div class="info-footer">
            <div class="info-content">
                <div class="info-item">
                    <i class="fas fa-shield-alt"></i>
                    <div class="info-text">
                        <h4>ความปลอดภัย</h4>
                        <p>ข้อมูลได้รับการเข้ารหัสและปกป้องอย่างปลอดภัย</p>
                    </div>
                </div>
                <div class="info-item">
                    <i class="fas fa-headset"></i>
                    <div class="info-text">
                        <h4>ฝ่ายสนับสนุน</h4>
                        <p>ติดต่อฝ่ายสนับสนุน 24/7 หากมีข้อสงสัย</p>
                    </div>
                </div>
            </div>
            <div class="footer-copyright">
                <p>&copy; 2025 ระบบบริหารจัดการคลินิกกายภาพบำบัด. All rights reserved.</p>
            </div>
        </div>
    </div>
</body>
</html>