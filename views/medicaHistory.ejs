<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600;700&family=Sarabun:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/medicaHistory.css">
</head>
<body>
    <!-- Page Header -->
    <header>
        <h1><i class="fas fa-file-medical"></i> <%= title %></h1>
    </header>

    <!-- Navigation -->
    <nav>
        <a href="/index"><i class="fas fa-home"></i> หน้าหลัก</a>
        <a href="/examinationroom/<%= patient ? patient.HN : '' %>"><i class="fas fa-stethoscope"></i> ห้องตรวจ</a>
        <a href="#" class="active"><i class="fas fa-users"></i> ประวัติผู้ป่วย</a>
    </nav>

    <div class="container">
        <% if (patient && medicalfrom) { %>
            <div class="patient-list fade-in">
                <div class="patient-entry">
                    <!-- Patient Information Header -->
                    <h3>
                        <i class="fas fa-user-injured"></i> 
                        ประวัติผู้ป่วย
                    </h3>
                    
                    <div class="patient-row">
                        <div>
                            <div class="patient-label">
                                <i class="fas fa-id-badge"></i> HN
                            </div>
                            <div class="patient-value"><%= patient.HN %></div>
                        </div>
                        <div>
                            <div class="patient-label">
                                <i class="fas fa-user"></i> ชื่อ
                            </div>
                            <div class="patient-value"><%= patient.fname %></div>
                        </div>
                        <div>
                            <div class="patient-label">
                                <i class="fas fa-user"></i> นามสกุล
                            </div>
                            <div class="patient-value"><%= patient.lname %></div>
                        </div>
                    </div>

                    <div class="patient-row2">
                        <div>
                            <div class="patient-label2">
                                <i class="fas fa-venus-mars"></i> เพศ
                            </div>
                            <div class="patient-value"><%= patient.gender %></div>
                        </div>

                    <!-- Body Measurements -->
                    <h4>
                        <i class="fas fa-weight"></i> 
                        ข้อมูลร่างกาย
                    </h4>
                    <div class="patient-row">
                        <div>
                            <div class="patient-label">
                                <i class="fas fa-weight-hanging"></i> น้ำหนัก
                            </div>
                            <div class="patient-value"><%= medicalfrom.weight %> </div>
                        </div>
                        <div>
                            <div class="patient-label">
                                <i class="fas fa-ruler-vertical"></i> ส่วนสูง
                            </div>
                            <div class="patient-value"><%= medicalfrom.height %> </div>
                        </div>
                        <div>
                            <div class="patient-label">
                                <i class="fas fa-calculator"></i> BMI
                            </div>
                            <div class="patient-value"><%= medicalfrom.bmi %></div>
                        </div>
                    </div>

                    <!-- Vital Signs -->
                    <h4>
                        <i class="fas fa-heartbeat"></i> 
                        สัญญาณชีพ
                    </h4>
                    <div class="patient-row">
                        <div>
                            <div class="patient-label">
                                <i class="fas fa-tint"></i> ความดันโลหิต
                            </div>
                            <div class="patient-value"><%= medicalfrom.bloodPressure %> </div>
                        </div>
                        <div>
                            <div class="patient-label">
                                <i class="fas fa-heart"></i> ชีพจร
                            </div>
                            <div class="patient-value"><%= medicalfrom.pulse %> </div>
                        </div>
                        <div>
                            <div class="patient-label">
                                <i class="fas fa-lungs"></i> O2Sat
                            </div>
                            <div class="patient-value"><%= medicalfrom.o2Sat %> </div>
                        </div>
                    </div>

                    <div class="patient-row">
                        <div>
                            <div class="patient-label">
                                <i class="fas fa-wind"></i> อัตราการหายใจ
                            </div>
                            <div class="patient-value"><%= medicalfrom.respiratoryRate %></div>
                        </div>
                    </div>

                    <!-- Medical History -->
                    <h4>
                        <i class="fas fa-notes-medical"></i> 
                        ประวัติการเจ็บป่วย
                    </h4>
                    
                    <div class="patient-row2">
                        <div>
                            <div class="patient-label2">
                                <i class="fas fa-exclamation-circle"></i> อาการสำคัญ
                            </div>
                            <div class="patient-value2"><%= medicalfrom.symptoms %></div>
                        </div>
                    </div>

                    <div class="patient-row2">
                        <div>
                            <div class="patient-label2">
                                <i class="fas fa-clock"></i> ประวัติปัจจุบัน
                            </div>
                            <div class="patient-value2"><%= medicalfrom.currentHistory %></div>
                        </div>
                    </div>

                    <div class="patient-row2">
                        <div>
                            <div class="patient-label2">
                                <i class="fas fa-history"></i> ประวัติอดีต
                            </div>
                            <div class="patient-value2"><%= medicalfrom.pastHistory %></div>
                        </div>
                    </div>
                </div>
            </div>

        <% } else { %>
            <div class="notice warning fade-in">
                <i class="fas fa-exclamation-circle"></i> 
                ไม่พบข้อมูลผู้ป่วยในระบบ
            </div>
        <% } %>

        <!-- Action Buttons -->
        <div class="fade-in" style="animation-delay: 0.3s;">
            <div class="button-group">
                <button class="button-confirm" onclick="goToExaminationRoom()">
                    <i class="fas fa-check-circle"></i> 
                    ยืนยัน
                </button>
                <button class="button3" onclick="goBack()">
                    <i class="fas fa-arrow-left"></i> 
                    ย้อนกลับ
                </button>
            </div>
        </div>
    </div>

    <!-- Enhanced JavaScript -->
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Enhanced back button functionality
            function goBack() {
                // Add loading state
                const backBtn = document.querySelector('.button3');
                const originalContent = backBtn.innerHTML;
                backBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> กำลังโหลด...';
                backBtn.disabled = true;
                
                // Go back in history
                setTimeout(() => {
                    if (window.history.length > 1) {
                        window.history.back();
                    } else {
                        // Fallback to index page if no history
                        window.location.href = '/index';
                    }
                }, 500);
                
                // Restore button after delay if still on page
                setTimeout(() => {
                    backBtn.innerHTML = originalContent;
                    backBtn.disabled = false;
                }, 3000);
            }
            
            // Go to examination room function
            function goToExaminationRoom() {
                // Add loading state
                const confirmBtn = document.querySelector('.button-confirm');
                const originalContent = confirmBtn.innerHTML;
                confirmBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> กำลังโหลด...';
                confirmBtn.disabled = true;
                
                // Navigate to examination room
                setTimeout(() => {
                    window.location.href = '/examinationroom/<%= patient ? patient.HN : "" %>';
                }, 500);
                
                // Restore button after delay if still on page
                setTimeout(() => {
                    confirmBtn.innerHTML = originalContent;
                    confirmBtn.disabled = false;
                }, 3000);
            }
            
            // Make functions globally accessible
            window.goBack = goBack;
            window.goToExaminationRoom = goToExaminationRoom;
            
            // Add smooth scroll behavior
            document.documentElement.style.scrollBehavior = 'smooth';
            
            // Add keyboard navigation
            document.addEventListener('keydown', function(e) {
                // ESC key to go back
                if (e.key === 'Escape') {
                    goBack();
                }
            });
        });
    </script>
</body>
</html>