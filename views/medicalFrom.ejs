<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ซักประวัติ</title>
    <link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600;700&family=Sarabun:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/medicalFrom.css">
</head>
<body>
    <div class="container">
        <h1><i class="fas fa-clipboard-list"></i> ซักประวัติ</h1>
        <% if (patient) { %>
        <div class="patient-entry">
            <div class="patient-row">
                <div>
                    <div class="patient-label"><i class="fas fa-id-badge"></i> HN:</div>
                    <div class="patient-value"><%= patient.HN %></div>
                </div>
                <div>
                    <div class="patient-label"><i class="fas fa-user"></i> ชื่อ:</div>
                    <div class="patient-value"><%= patient.fname %></div>
                </div>
                <div>
                    <div class="patient-label">นามสกุล:</div>
                    <div class="patient-value"><%= patient.lname %></div>
                </div>
            </div>
        </div>
        <% } %>

        <form action="/medicalFrom/<%= patient.HN %>" method="POST" id="historyForm">
            <h3><i class="fas fa-weight"></i> ข้อมูลร่างกาย</h3>
            <div class="form-row">
                <div class="input-container">
                    <input type="text" id="weight" name="weight" placeholder="น้ำหนัก" required>
                    <span class="unit">kg</span>
                </div>
                <div class="input-container">
                    <input type="text" id="height" name="height" placeholder="ส่วนสูง" required>
                    <span class="unit">cm</span>
                </div>
            </div>
          
            <h3><i class="fas fa-heartbeat"></i> สัญญาณชีพ</h3>
            <div class="form-row">
                <div class="input-container">
                    <input type="text" id="bloodPressure" name="bloodPressure" placeholder="ความดันโลหิต" required>
                    <span class="unit">mmHg</span>
                </div>
                <div class="input-container">
                    <input type="text" id="pulse" name="pulse" placeholder="ชีพจร" required>
                    <span class="unit">/min</span>
                </div>
            </div>
          
            <div class="form-row">
                <div class="input-container">
                    <input type="text" id="o2Sat" name="o2Sat" placeholder="O2Sat" required>
                    <span class="unit">%</span>
                </div>
                <div class="input-container">
                    <input type="text" id="respiratoryRate" name="respiratoryRate" placeholder="อัตราการหายใจ" required>
                    <span class="unit">/min</span>
                </div>
            </div>
          
            <div class="form-row">
                <div class="input-container">
                    <input type="number" id="bmi" name="bmi" placeholder="BMI" required>
                </div>
            </div>
          
            <h3><i class="fas fa-notes-medical"></i> ประวัติการเจ็บป่วย</h3>
                        <div class="form-row">
                <div class="input-container2">
                    <textarea id="symptoms" name="symptoms" placeholder="อาการสำคัญ" required></textarea>
                </div>
            </div>

            <div class="form-row">
                <div class="input-container2">
                    <textarea id="currentHistory" name="currentHistory" placeholder="ประวัติปัจจุบัน" required></textarea>
                </div>
            </div>
          
            <div class="form-row">
                <div class="input-container2">
                    <textarea id="pastHistory" name="pastHistory" placeholder="ประวัติอดีต" required></textarea>
                </div>
            </div>
          
            <button type="submit">
                <i class="fas fa-save"></i> บันทึกข้อมูล
            </button>
            <button type="button" class="button2" onclick="goBack()">
                <i class="fas fa-arrow-left"></i> ย้อนกลับ
            </button>
        </form>
    </div>

    <script src="/js/medicalFrom.js" ></script>
</body>
</html>  