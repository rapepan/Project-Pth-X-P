<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ซักประวัติ</title>
    <link rel="stylesheet" href="/css/medicalHistory.css">
</head>

<body>

    <div class="container">
        <h1>ซักประวัติ</h1>
        <% if (patient) { %>
        <div class="patient-row">
            <div class="patient-label">HN:</div>
            <div class="patient-value"><%= patient.HN %></div>
    
            <div class="patient-label">ชื่อ:</div>
            <div class="patient-value"><%= patient.fname %></div>
    
            <div class="patient-label">นามสกุล:</div>
            <div class="patient-value"><%= patient.lname %></div>
        </div>
        <% } else { %>
            <!-- ถ้าไม่มีข้อมูลผู้ป่วย (เมื่อไม่มี id ใน URL) -->
        <% } %>

        <form action="/medicalHistory/<%= patient.id %>" method="POST" id="historyForm">
            <div class="form-row">
              <div class="input-container">
                <input type="text" id="weight" name="weight" placeholder="น้ำหนัก" required>
                <span class="unit">kg</span>
              </div>
              <div class="input-container">
                <input type="text" id="height" name="height" placeholder="ส่วนสูง" required>
                <span class="unit">cm</span>
              </div>
            </div>
          
            <div class="form-row">
              <div class="input-container">
                <input type="text" id="bloodPressure" name="bloodPressure" placeholder="ความดันโลหิต" required>
                <span class="unit">mmHg</span>
              </div>
              <div class="input-container">
                <input type="text" id="pulse" name="pulse" placeholder="ชีพจร" required>
                <span class="unit">/min</span>
              </div>
            </div>
          
            <div class="form-row">
              <div class="input-container">
                <input type="text" id="o2Sat" name="o2Sat" placeholder="O2Sat" required>
                <span class="unit">%</span>
              </div>
              <div class="input-container">
                <input type="text" id="respiratoryRate" name="respiratoryRate" placeholder="อัตราการหายใจ" required>
                <span class="unit">/min</span>
              </div>
            </div>
          
            <div class="form-row">
              <div class="input-container">
                <input type="number" id="bmi" name="bmi" placeholder="BMI" required>
              </div>
            </div>
          
            <div class="form-row">
              <div class="input-container2">
                <textarea id="symptoms" name="symptoms" placeholder="อาการสำคัญ" required></textarea>
              </div>
            </div>
          
            <div class="form-row">
              <div class="input-container2">
                <textarea id="currentHistory" name="currentHistory" placeholder="ประวัติปัจจุบัน" required></textarea>
              </div>
            </div>
          
            <div class="form-row">
              <div class="input-container2">
                <textarea id="pastHistory" name="pastHistory" placeholder="ประวัติอดีต" required></textarea>
              </div>
            </div>
          
            <button type="submit">บันทึกข้อมูล</button><br><br>
            <button class="button2" onclick="goBack()">ย้อนกลับ</button>
        </form>
              
    </div>
</body>

<script>
    document.getElementById("historyForm").addEventListener("submit", function(event) {
      // รวมตัวเลขและหน่วยเข้าด้วยกันก่อนส่ง
      var weight = document.getElementById("weight").value + "kg";
      var height = document.getElementById("height").value + "cm";
      var bloodPressure = document.getElementById("bloodPressure").value + "mmHg";
      var pulse = document.getElementById("pulse").value + "/min";
      var o2Sat = document.getElementById("o2Sat").value + "%";
      var respiratoryRate = document.getElementById("respiratoryRate").value + "/min";

      // กำหนดค่าที่รวมแล้วลงในฟอร์มเพื่อส่งไปยังเซิร์ฟเวอร์
      document.getElementById("weight").value = weight;
      document.getElementById("height").value = height;
      document.getElementById("bloodPressure").value = bloodPressure;
      document.getElementById("pulse").value = pulse;
      document.getElementById("o2Sat").value = o2Sat;
      document.getElementById("respiratoryRate").value = respiratoryRate;
    });

    function goBack() {
      window.history.back(); // หรือใช้ window.history.go(-1);
    }
  </script>

</html>