<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ลงทะเบียนผู้ป่วยใหม่</title>
    <link rel="stylesheet" href="/css/patientForm.css">
</head>
<body>
    <div class="container">
        <h1>ลงทะเบียนผู้ป่วยใหม่</h1>
        <form action="/patients/add" method="POST">
            <h4>ข้อมูลส่วนตัว</h4>
            <div class="form-row">
                <div class="input-container">
                    <input type="text" id="fname" name="fname" placeholder="ชื่อ" required>
                </div>
                <div class="input-container">
                    <input type="text" id="lname" name="lname" placeholder="นามสกุล" required>
                </div>
            </div>

            <div class="form-row">
                <div class="input-container">
                    <input type="text" id="national_id" name="national_id" placeholder="เลขบัตรประจำตัวประชาชน" required>                   
                </div>
                <div class="input-container">
                    <select id="gender" name="gender" required>
                        <option value="" disabled selected>เพศ</option>
                        <option value="ชาย">ชาย</option>
                        <option value="หญิง">หญิง</option>
                    </select>
                </div>
            </div>

            <div class="form-row">
                <div class="input-container">
                    <input type="number" id="phone" name="phone" placeholder="เบอร์ติดต่อ" required>
                </div>
                <div class="input-container">
                    <input type="number" id="age" name="age" placeholder="อายุ" required>
                </div>
            </div>
            
            <div class="form-row">
                <div class="input-container">
                    <input type="date" id="dob" name="dob" placeholder="วันเดือนปีเกิด" required>
                </div>                              
                <div class="input-container">
                    <input type="text" id="chronic_diseases" name="chronic_diseases" placeholder="โรคประจำตัว (ถ้ามี)" required>
                </div>
            </div>

            <div class="form-row">
                <div class="input-container">
                    <input type="text" id="allergy_history" name="allergy_history" placeholder="ประวัติการแพ้ยา (ถ้ามี)" required>
                </div>
            </div>

            <h4>ที่อยู่ปัจุบัน</h4>
            <div class="form-row">
                <div class="input-container">
                    <input type="text" id="housenumber" name="housenumber" placeholder="เลขที่" required>
                </div>
                <div class="input-container">
                    <input type="text" id="moo" name="moo" placeholder="หมู่" required>
                </div>
            </div>

            <div class="form-row">
                <div class="input-container">
                    <input type="text" id="soi" name="soi" placeholder="ซอย" required>
                </div>
                <div class="input-container">
                    <input type="text" id="subdistrict" name="subdistrict" placeholder="ตำบล/แขวง" required>
                </div>
            </div>

            <div class="form-row">
                <div class="input-container">
                    <input type="text" id="district" name="district" placeholder="อำเภอ/เขต" required>
                </div>
                <div class="input-container">
                    <input type="text" id="province" name="province" placeholder="จังหวัด" required>
                </div>
            </div>

            <div class="form-row">
                <div class="input-container">
                    <input type="number" id="postcode" name="postcode" placeholder="รหัสไปรษณีย์" required>
                </div>
            </div>
            
            <h4>ข้อมูลติดต่อกรณีฉุกเฉิน</h4>
            <div class="form-row">
                <div class="input-container">
                    <input type="text" id="emergency_fname" name="emergency_fname" placeholder="ชื่อ" required>
                </div>
                <div class="input-container">
                    <input type="text" id="emergency_lname" name="emergency_lname" placeholder="นามสกุล" required>
                </div>
            </div>

            <div class="form-row">
                <div class="input-container">
                    <input type="number" id="emergency_phone" name="emergency_phone" placeholder="เบอร์ติดต่อ" required>
                </div>
                <div class="input-container">
                    <input type="text" id="relationships" name="relationships" placeholder="ความสัมพันธ์" required>
                </div>
            </div>

            <button type="submit">บันทึกข้อมูล</button><br><br>
            <button class="button2" onclick="goBack()">ย้อนกลับ</button>
        </form>
    </div>
</body>

<script>
    function goBack() {
    window.history.back(); // หรือใช้ window.history.go(-1);
}

</script>

</html>
