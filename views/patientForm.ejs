<!DOCTYPE html>
<html lang="th">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>เพิ่มข้อมูลผู้ป่วยใหม่</title>
</head>

<body>
    <h1>เพิ่มข้อมูลผู้ป่วยใหม่</h1>
    <form action="/patients/add" method="POST">
        <label for="name">ชื่อ:</label>
        <input type="text" id="name" name="name" required><br><br>

        <label for="national_id">รหัสประจำตัวประชาชน:</label>
        <input type="text" id="national_id" name="national_id" required><br><br>

        <label for="age">อายุ:</label>
        <input type="number" id="age" name="age" required><br><br>

        <label for="gender">เพศ:</label>
        <select id="gender" name="gender" required>
            <option value="ชาย">ชาย</option>
            <option value="หญิง">หญิง</option>
        </select><br><br>

        <label for="address">ที่อยู่:</label>
        <textarea id="address" name="address" required></textarea><br><br>

        <label for="height">ส่วนสูง:</label>
        <input type="number" step="0.01" id="height" name="height" required><br><br>

        <label for="weight">น้ำหนัก:</label>
        <input type="number" step="0.01" id="weight" name="weight" required><br><br>

        <label for="bmi">BMI:</label>
        <input type="number" step="0.01" id="bmi" name="bmi" required><br><br>

        <label for="blood_pressure">ความดันโลหิต:</label>
        <input type="text" id="blood_pressure" name="blood_pressure" required><br><br>

        <label for="chronic_diseases">โรคประจำตัว:</label>
        <textarea id="chronic_diseases" name="chronic_diseases"></textarea><br><br>

        <label for="reason_for_visit">เหตุผลที่มาคลินิก:</label>
        <textarea id="reason_for_visit" name="reason_for_visit"></textarea><br><br>

        <label for="treatment_history">ประวัติการรักษา:</label>
        <textarea id="treatment_history" name="treatment_history"></textarea><br><br>

        <button type="submit">บันทึกข้อมูล</button>
    </form>
</body>

</html>