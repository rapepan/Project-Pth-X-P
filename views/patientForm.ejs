<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ลงทะเบียนผู้ป่วยใหม่</title>
    <link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600;700&family=Sarabun:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/patientForm.css">
</head>
<body>
    <header class="sticky-header">
        <div class="header-content">
            <div class="logo-section">
                <h1>
                    <i class="fas fa-diagnoses"></i>
                    <%= title %>
                </h1>
            </div>
            <div class="user-info">
                <span><%= user.fullname || user.username %></span>
            </div>
        </div>
    </header>

    <div class="main-container">
        <div class="hero-section">
            <h1><i class="fas fa-user-plus"></i> ลงทะเบียนผู้ป่วยใหม่</h1>
        </div>
        
        <!-- แสดง Error Messages ถ้ามี -->
        <% if (typeof errors !== 'undefined' && errors.length > 0) { %>
            <div class="alert alert-danger">
                <ul>
                    <% errors.forEach(function(error) { %>
                        <li><%= error %></li>
                    <% }); %>
                </ul>
            </div>
        <% } %>
        
        <!-- แสดง Success Message ถ้ามี -->
        <% if (typeof message !== 'undefined' && message) { %>
            <div class="alert alert-success">
                <%= message %>
            </div>
        <% } %>
        
        <form action="/patients/add" method="POST">
            <h3><i class="fas fa-id-card"></i> ข้อมูลส่วนตัว</h3>
            <div class="form-row">
                <div class="input-container">
                    <input type="text" id="fname" name="fname" placeholder="ชื่อ *" required>
                </div>
                <div class="input-container">
                    <input type="text" id="lname" name="lname" placeholder="นามสกุล *" required>
                </div>
            </div>

            <div class="form-row">
                <div class="input-container">
                    <input type="text" id="national_id" name="national_id" placeholder="เลขบัตรประจำตัวประชาชน (13 หลัก) *" 
                           pattern="[0-9]{13}" maxlength="13" required>
                </div>
                <div class="input-container">
                    <select id="gender" name="gender" required>
                        <option value="" disabled selected>เพศ *</option>
                        <option value="ชาย">ชาย</option>
                        <option value="หญิง">หญิง</option>
                    </select>
                </div>
            </div>

            <div class="form-row">
                <div class="input-container">
                    <input type="tel" id="phone" name="phone" placeholder="เบอร์ติดต่อ (10 หลัก) *"
                           pattern="[0-9]{10}" maxlength="10" required>
                </div>
            </div>
            
            <div class="form-row">
                <div class="input-container">
                    <label for="dob" style="display:block; margin-bottom:5px; color:#666;">วันเดือนปีเกิด *</label>
                    <input type="date" id="dob" name="dob" required>
                </div>
                <div class="input-container">
                    <label for="dob" style="display:block; margin-bottom:5px; color:#666;">‎</label>
                    <input type="text" id="chronic_diseases" name="chronic_diseases" 
                           placeholder="โรคประจำตัว (ถ้าไม่มีใส่ - )">
                </div>
            </div>

            <div class="form-row">
                <div class="input-container">
                    <input type="text" id="allergy_history" name="allergy_history" 
                           placeholder="ประวัติการแพ้ยา (ถ้าไม่มีใส่ - )">
                </div>
            </div>

            <h3><i class="fas fa-map-marker-alt"></i> ที่อยู่ปัจจุบัน</h3>
            <div class="form-row">
                <div class="input-container">
                    <input type="text" id="housenumber" name="housenumber" placeholder="เลขที่ *" required>
                </div>
                <div class="input-container">
                    <input type="text" id="moo" name="moo" placeholder="หมู่ (ถ้าไม่มีใส่ - )">
                </div>
            </div>

            <div class="form-row">
                <div class="input-container">
                    <input type="text" id="soi" name="soi" placeholder="ซอย (ถ้าไม่มีใส่ - )">
                </div>
                <div class="input-container">
                    <input type="text" id="subdistrict" name="subdistrict" placeholder="ตำบล/แขวง *" required>
                </div>
            </div>

            <div class="form-row">
                <div class="input-container">
                    <input type="text" id="district" name="district" placeholder="อำเภอ/เขต *" required>
                </div>
                <div class="input-container">
                    <input type="text" id="province" name="province" placeholder="จังหวัด *" required>
                </div>
            </div>

            <div class="form-row">
                <div class="input-container">
                    <input type="text" id="postcode" name="postcode" placeholder="รหัสไปรษณีย์ (5 หลัก) *" 
                           pattern="[0-9]{5}" maxlength="5" required>
                </div>
            </div>
            
            <h3><i class="fas fa-phone-alt"></i> ข้อมูลติดต่อกรณีฉุกเฉิน</h3>
            <div class="form-row">
                <div class="input-container">
                    <input type="text" id="emergency_fname" name="emergency_fname" placeholder="ชื่อ *" required>
                </div>
                <div class="input-container">
                    <input type="text" id="emergency_lname" name="emergency_lname" placeholder="นามสกุล *" required>
                </div>
            </div>

            <div class="form-row">
                <div class="input-container">
                    <input type="tel" id="emergency_phone" name="emergency_phone" 
                           placeholder="เบอร์ติดต่อ (10 หลัก) *" 
                           pattern="[0-9]{10}" maxlength="10" required>
                </div>
                <div class="input-container">
                    <input type="text" id="relationships" name="relationships" placeholder="ความสัมพันธ์ *" required>
                </div>
            </div>

            <p style="color: #666; font-size: 14px; margin-top: 20px;">
                <i class="fas fa-info-circle"></i> หมายเหตุ: * คือข้อมูลที่จำเป็นต้องกรอก
            </p>

            <button type="submit" id="patientSubmitBtn">
                <i></i>
                <span class="btn-text">บันทึกข้อมูล</span>
                <span class="btn-loading" style="display: none;">
                    <i class="fas fa-spinner fa-spin"></i>
                    กำลังบันทึก...
                </span>
            </button>
            <button type="button" class="button2" onclick="goBack()">
                <i></i> ย้อนกลับ
            </button>
        </form>
    </div>

    <script src="/js/patientForm.js" ></script>
</body>
</html>  