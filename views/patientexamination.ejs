<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600;700&family=Sarabun:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/examinationroom.css">
    <link rel="stylesheet" href="/css/patientexamination.css">

</head>
<body>
    <!-- Sticky Header - ใช้ธีมเดียวกับ index.css -->
    <header class="sticky-header">
        <div class="header-content">
            <div class="logo-section">
                <h1>
                    <i class="fas fa-user-md"></i>
                    <%= title %>
                </h1>
            </div>
            <div class="user-info">
                <span><%= user.fullname || user.username %></span>
            </div>
        </div>
    </header>

    <!-- Navigation -->
    <nav>
        <a href="/index"><i class="fas fa-home"></i> หน้าหลัก</a>
        <% if (typeof patient !== 'undefined' && patient) { %>
            <a href="/examinationroom/<%= patient.HN %>"><i class="fas fa-stethoscope"></i> ห้องตรวจ</a>
            <a href="/patientexamination/<%= patient.HN %>" class="active"><i class="fas fa-user-md"></i> ตรวจร่างกาย</a>
            <!-- เมนูสำหรับ Physical Therapist และ Admin เท่านั้น -->
            <% if (user.role === 'physical_therapist' || user.role === 'admin') { %>
                <a href="/diagnosis/<%= patient.HN %>"><i class="fas fa-diagnoses"></i> การวินิจฉัย</a>
                <a href="/procedure/<%= patient.HN %>"><i class="fas fa-hand-holding-medical"></i> หัตถการ</a>
                <a href="/ptdata/<%= patient.HN %>"><i class="fas fa-chart-line"></i> สรุปผลการรักษา</a>
            <% } %>
            <!-- เมนูสำหรับทุกคน -->
            <a href="/billing/<%= patient.HN %>"><i class="fas fa-file-invoice-dollar"></i> สรุปค่าใช้จ่าย</a>
        <% } else { %>
            <a href="/examinationroom"><i class="fas fa-stethoscope"></i> ห้องตรวจ</a>
        <% } %>
    </nav>

    <div class="main-container">


        <% if (errors && errors.length > 0) { %>
            <div class="error-message fade-in">
                <strong><i class="fas fa-exclamation-triangle"></i> พบข้อผิดพลาด:</strong>
                <ul style="margin: 0.5rem 0 0 1.5rem;">
                    <% errors.forEach(error => { %>
                        <li><%= error %></li>
                    <% }); %>
                </ul>
            </div>
        <% } %>

        <% if (patient) { %>

            <!-- Patient Examination Form -->
            <form action="/patientexamination/<%= patient.HN %>" method="POST" onkeydown="if(event.key === 'Enter' && event.target.type !== 'textarea') return false;">
                <!-- Basic Information -->
                <div class="form-section fade-in" style="animation-delay: 0.1s;">
                    <h3><i class="fas fa-info-circle"></i> ข้อมูลผู้ป่วย</h3>
                    <div class="form-grid">
                        <div class="form-group">
                            <label>
                                <i class="fas fa-user"></i> HN <span class="required"></span>
                            </label>
                            <input type="text" name="HN" value="<%= patient.HN %>" readonly>
                        </div>
                        <div class="form-group">
                            <label>
                                <i class="fas fa-user"></i> ชื่อผู้ป่วย <span class="required"></span>
                            </label>
                            <input type="text" name="patient_name" value="<%= patient.fname %> <%= patient.lname %>" readonly>
                        </div>
                        <div class="form-group">
                            <label><i class="fas fa-calendar"></i> อายุ</label>
                            <input type="number" name="age" value="<%= patient.age %>" readonly>
                        </div>
                    </div>
                </div>

                <!-- Observation & Palpation -->
                <div class="form-section fade-in" style="animation-delay: 0.3s;">
                    <h3><i class="fas fa-eye"></i> การสังเกต (Observation) และการคลำ (Palpation)</h3>
                    <div class="form-group">
                        <label><i class="fas fa-eye"></i> การสังเกต (Observation) <span class="required">*</span></label>
                        <textarea name="observation" rows="6" placeholder="บันทึกผลการสังเกตอาการของผู้ป่วย" required></textarea>
                    </div>
                    <div class="form-group">
                        <label><i class="fas fa-hand-paper"></i> การคลำ (Palpation) <span class="required">*</span></label>
                        <textarea name="palpation" rows="6" placeholder="บันทึกผลการคลำตรวจ " required></textarea>
                    </div>
                </div>

                 <!-- Range of Motion & Movement Tests -->
                <div class="form-section fade-in" style="animation-delay: 0.5s;">
                    <h3><i class="fas fa-running"></i> การทดสอบการเคลื่อนไหว</h3>
                    
                    <!-- ROM Test -->
                    <div class="form-group">
                        <label><i class="fas fa-arrows-alt"></i> ROM (Range of Motion)</label>
                        <div class="radio-option">
                            <input type="checkbox" name="romWNL" id="rom-wnl" value="1">
                            <label for="rom-wnl">WNL (Within Normal Limits)</label>
                        </div>
                        <div class="radio-option">
                            <input type="checkbox" name="romWeakness" id="rom-weakness" value="1">
                            <label for="rom-weakness">Limited</label>
                        </div>
                        <div class="detail-input-container">
                            <input type="text" name="romNotes1" class="detail-input" data-toggle="rom-weakness" placeholder="ระบุตำแหน่งและระดับการจำกัดการเคลื่อนไหว">
                        </div>
                    </div>

                    <!-- MMT Test -->
                    <div class="form-group">
                        <label><i class="fas fa-dumbbell"></i> MMT (Manual Muscle Testing)</label>
                        <div class="radio-option">
                            <input type="checkbox" name="mmtNormal" id="mmt-normal" value="1">
                            <label for="mmt-normal">Normal</label>
                        </div>
                        <div class="radio-option">
                            <input type="checkbox" name="mmtLimited" id="mmt-limited" value="1">
                            <label for="mmt-limited">Weakness</label>
                        </div>
                        <div class="detail-input-container">
                            <input type="text" name="mmtNotes1" class="detail-input" data-toggle="mmt-limited" placeholder="ระบุกล้ามเนื้อและระดับความแข็งแรง (0-5)">
                        </div>
                    </div>

                    <!-- Accessory Movement -->
                    <div class="form-group">
                        <label><i class="fas fa-hand-holding-heart"></i> Accessory Movement</label>
                        <div class="radio-option">
                            <input type="checkbox" name="accessoryNormal" id="accessory-normal" value="1">
                            <label for="accessory-normal">Normal</label>
                        </div>
                        <div class="radio-option">
                            <input type="checkbox" name="accessoryHypomobility" id="accessory-hypomobility" value="1">
                            <label for="accessory-hypomobility">Hypomobility</label>
                        </div>
                        <div class="detail-input-container">
                            <input type="text" name="accessoryNotes1" class="detail-input" data-toggle="accessory-hypomobility" placeholder="ระบุข้อความผิดปกติ">
                        </div>
                        <div class="radio-option">
                            <input type="checkbox" name="accessoryHypermobility" id="accessory-hypermobility" value="1">
                            <label for="accessory-hypermobility">Hypermobility</label>
                        </div>
                        <div class="detail-input-container">
                            <input type="text" name="accessoryNotes2" class="detail-input" data-toggle="accessory-hypermobility" placeholder="ระบุข้อความผิดปกติ">
                        </div>
                    </div>
                </div>

                <!-- Special Tests -->
                <div class="form-section fade-in" style="animation-delay: 0.7s;">
                    <h3><i class="fas fa-clipboard-check"></i> การทดสอบพิเศษ</h3>
                    
                    <!-- Sensory Test -->
                    <div class="form-group">
                        <label><i class="fas fa-hand-paper"></i> Sensory Test</label>

                        <!-- Pinprick -->
                        <div class="radio-option">
                            <input type="checkbox" name="sensoryPinprick" id="sensory-pinprick" value="1">
                            <label for="sensory-pinprick"><strong>Pinprick</strong></label>
                        </div>
                        <div class="sub-options-container" data-parent="sensory-pinprick" style="margin-left: 30px;">
                            <div class="radio-option">
                                <input type="checkbox" name="pinprickIntact" id="pinprick-intact" value="1">
                                <label for="pinprick-intact">Intact</label>
                            </div>
                            <div class="detail-input-container">
                                <input type="text" name="pinprickNotes1" class="detail-input" data-toggle="pinprick-intact" placeholder="ระบุบริเวณที่ตรวจพบ">
                            </div>
                            <div class="radio-option">
                                <input type="checkbox" name="pinprickImpair" id="pinprick-impair" value="1">
                                <label for="pinprick-impair">Impair</label>
                            </div>
                            <div class="detail-input-container">
                                <input type="text" name="pinprickNotes2" class="detail-input" data-toggle="pinprick-impair" placeholder="ระบุบริเวณที่มีความรู้สึกลดลง">
                            </div>
                            <div class="radio-option">
                                <input type="checkbox" name="pinprickLoss" id="pinprick-loss" value="1">
                                <label for="pinprick-loss">Loss</label>
                            </div>
                            <div class="detail-input-container">
                                <input type="text" name="pinprickNotes3" class="detail-input" data-toggle="pinprick-loss" placeholder="ระบุบริเวณที่สูญเสียความรู้สึก">
                            </div>
                        </div>

                        <!-- Light Touch -->
                        <div class="radio-option" style="margin-top: 10px;">
                            <input type="checkbox" name="sensoryLightTouch" id="sensory-light-touch" value="1">
                            <label for="sensory-light-touch"><strong>Light Touch</strong></label>
                        </div>
                        <div class="sub-options-container" data-parent="sensory-light-touch" style="margin-left: 30px;">
                            <div class="radio-option">
                                <input type="checkbox" name="lightTouchIntact" id="light-touch-intact" value="1">
                                <label for="light-touch-intact">Intact</label>
                            </div>
                            <div class="radio-option">
                                <input type="checkbox" name="lightTouchImpair" id="light-touch-impair" value="1">
                                <label for="light-touch-impair">Impair</label>
                            </div>
                            <div class="detail-input-container">
                                <input type="text" name="lightTouchNotes1" class="detail-input" data-toggle="light-touch-impair" placeholder="ระบุบริเวณที่มีความรู้สึกลดลง">
                            </div>
                            <div class="radio-option">
                                <input type="checkbox" name="lightTouchLoss" id="light-touch-loss" value="1">
                                <label for="light-touch-loss">Loss</label>
                            </div>
                            <div class="detail-input-container">
                                <input type="text" name="lightTouchNotes2" class="detail-input" data-toggle="light-touch-loss" placeholder="ระบุบริเวณที่สูญเสียความรู้สึก">
                            </div>
                        </div>
                    </div>

                    <!-- Deep Tendon Reflex -->
                    <div class="form-group">
                        <label><i class="fas fa-heartbeat"></i> Deep Tendon Reflex</label>
                        <div class="radio-option">
                            <input type="checkbox" name="normalDTR" id="dtr-normal" value="1">
                            <label for="dtr-normal">Normal of</label>
                        </div>
                        <div class="detail-input-container">
                            <input type="text" name="deepTendonReflexNotes1" class="detail-input" data-toggle="dtr-normal" placeholder="ระบุตำแหน่ง">
                        </div>
                        <div class="radio-option">
                            <input type="checkbox" name="abnormalDTR" id="dtr-abnormal" value="1">
                            <label for="dtr-abnormal">Abnormal of</label>
                        </div>
                        <div class="detail-input-container">
                            <input type="text" name="deepTendonReflexNotes2" class="detail-input" data-toggle="dtr-abnormal" placeholder="ระบุตำแหน่ง">
                        </div>
                    </div>

                    <!-- Transfer -->
                    <div class="form-group">
                        <label><i class="fas fa-exchange-alt"></i> Transfer</label>
                        <div class="radio-option">
                            <input type="checkbox" name="transferIndependent" id="transfer-independent" value="1">
                            <label for="transfer-independent"><strong>Independent</strong></label>
                        </div>
                        <div class="radio-option" style="margin-top: 10px;">
                            <input type="checkbox" name="transferDependent" id="transfer-dependent" value="1">
                            <label for="transfer-dependent"><strong>Dependent</strong></label>
                        </div>
                        <div class="detail-input-container">
                            <input type="text" name="transferNotes2" class="detail-input" data-toggle="transfer-dependent" placeholder="ระบุระดับการพึ่งพา เช่น ต้องช่วย 1 คน, 2 คน">
                        </div>
                    </div>

                    <!-- Ambulation -->
                    <div class="form-group">
                        <label><i class="fas fa-walking"></i> Ambulation</label>
                        <div class="radio-option">
                            <input type="checkbox" name="ambulationIndependent" id="ambulation-independent" value="1">
                            <label for="ambulation-independent"><strong>Independent</strong></label>
                        </div>
                        <div style="margin-left: 30px;">
                            <div class="radio-option">
                                <input type="checkbox" name="ambulationHandFree" id="ambulation-hand-free" value="1">
                                <label for="ambulation-hand-free">Hand-Free</label>
                            </div>
                            <div class="radio-option">
                                <input type="checkbox" name="ambulationWith" id="ambulation-with" value="1">
                                <label for="ambulation-with">With</label>
                            </div>
                            <div class="detail-input-container">
                                <input type="text" name="ambulationNotes1" class="detail-input" data-toggle="ambulation-with" placeholder="ระบุอุปกรณ์ช่วยเดิน เช่น Walker, Cane, Crutches">
                            </div>
                        </div>
                        <div class="radio-option" style="margin-top: 10px;">
                            <input type="checkbox" name="ambulationDependent" id="ambulation-dependent" value="1">
                            <label for="ambulation-dependent"><strong>Dependent</strong></label>
                        </div>
                        <div class="detail-input-container">
                            <input type="text" name="ambulationNotes2" class="detail-input" data-toggle="ambulation-dependent" placeholder="ระบุระดับการพึ่งพาในการเดิน">
                        </div>
                    </div>
                </div>

                <!-- Additional Notes -->
                <div class="form-section fade-in" style="animation-delay: 0.8s;">
                    <h3><i class="fas fa-sticky-note"></i> หมายเหตุเพิ่มเติม</h3>
                    <div class="form-group">
                        <label><i class="fas fa-comment-dots"></i> หมายเหตุเพิ่มเติม</label>
                        <textarea name="notes" rows="8" placeholder="บันทึกข้อมูลเพิ่มเติมหรือข้อสังเกตอื่นๆ"></textarea>
                    </div>
                </div>

                <!-- Submit Buttons -->
                <div class="btn-group fade-in" style="animation-delay: 0.9s;">
                    <button type="submit" class="btn-primary">
                        <i class="fas fa-save"></i> บันทึกข้อมูล
                    </button>
                    <button type="button" class="btn-secondary" onclick="window.history.back()">
                        <i class="fas fa-times"></i> ยกเลิก
                    </button>
                </div>
            </form>

        <% } else { %>
            <div class="no-patient-section fade-in">
                <div class="no-patient-icon">
                    <i class="fas fa-user-plus"></i>
                </div>
                <h2>ยังไม่ได้เลือกผู้ป่วย</h2>
                <p>กรุณาเลือกผู้ป่วยเพื่อเริ่มการตรวจร่างกาย</p>
                <div class="no-patient-actions">
                    <button class="action-btn primary" onclick="window.location.href='/patients'">
                        <i class="fas fa-search"></i>
                        <span>ค้นหาผู้ป่วย</span>
                    </button>
                </div>
            </div>
        <% } %>
    </div>

    <!-- External JavaScript File (if exists) -->
    <script src="/js/patientexamination.js"></script>
</body>
</html>