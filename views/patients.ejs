<!DOCTYPE html>
<html lang="th">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link rel="stylesheet" href="/css/patients.css"> <!-- ใช้ CSS เฉพาะหน้า Patients -->
</head>

<body>
    <header>
        <h1>
            <%= title %>
        </h1>
    </header>

    <nav>
        <a href="/index">หน้าหลัก</a>
        <a href="/patients">ค้นหาข้อมูลผู้ป่วย</a>
    </nav>

    <div class="container">
        <h2>ค้นหาผู้ป่วย</h2>
        <!-- ฟอร์มค้นหาผู้ป่วย -->
        <form class="search-bar" action="/patients" method="GET">
            <select name="searchType">
                <option value="HN" <%=searchType==='HN' ? 'selected' : '' %>>ค้นหาด้วย HN</option>
                <option value="fname" <%=searchType==='fname' ? 'selected' : '' %>>ค้นหาด้วยชื่อ</option>
                <option value="national_id" <%=searchType==='national_id' ? 'selected' : '' %>>ค้นหาตามรหัสบัตรประชาชน</option>
            </select>
            <input type="text" name="search" placeholder="ค้นหาผู้ป่วย" value="<%= searchTerm %>">
            <button type="submit">ค้นหา</button>
        </form>

        <% if (patients.length > 0 && searchTerm) { %>
            <h3>ผลการค้นหา</h3>
            <div class="patient-list">
                <% patients.forEach(function(patient) { %>
                    <div class="patient-entry">
                        <h4>ข้อมูลส่วนตัว</h4>
                        <div class="patient-row">
                            <div class="patient-label">HN:</div>
                            <div class="patient-value"><%= patient.HN %></div>

                            <div class="patient-label">ชื่อ:</div>
                            <div class="patient-value"><%= patient.fname %></div>

                            <div class="patient-label">นามสกุล:</div>
                            <div class="patient-value"><%= patient.lname %></div>
                        </div>
                        
                        <div class="patient-row">
                            <div class="patient-label">รหัสประจำตัวประชาชน:</div>
                            <div class="patient-value"><%= patient.national_id %></div>

                            <div class="patient-label">เพศ:</div>
                            <div class="patient-value"><%= patient.gender %></div>

                            <div class="patient-label">เบอร์ติดต่อ:</div>
                            <div class="patient-value"><%= patient.phone %></div>
                        </div>

                        <div class="patient-row">
                            <div class="patient-label">อายุ:</div>
                            <div class="patient-value"><%= patient.age %></div>

                            <div class="patient-label">วันเดือนปีเกิด:</div>
                            <div class="patient-value">
                                <%= new Date(patient.dob).toLocaleDateString('th-TH') %>
                            </div>

                            <div class="patient-label">โรคประจำตัว:</div>
                            <div class="patient-value"><%= patient.chronic_diseases %></div>
                        </div>

                        <div class="patient-row">
                            <div class="patient-label">ประวัติการแพ้ยา:</div>
                            <div class="patient-value2"><%= patient.allergy_history %></div>
                        </div>

                        <h4>ที่อยู่ปัจุบัน</h4>
                        <div class="patient-row">
                            <div class="patient-label">เลขที่:</div>
                            <div class="patient-value"><%= patient.housenumber %></div>

                            <div class="patient-label">หมู่:</div>
                            <div class="patient-value"><%= patient.moo %></div>

                            <div class="patient-label">ซอย:</div>
                            <div class="patient-value"><%= patient.soi %></div>
                        </div>

                        <div class="patient-row">
                            <div class="patient-label">ตำบล/แขวง:</div>
                            <div class="patient-value"><%= patient.subdistrict %></div>
                            
                            <div class="patient-label">อำเภอ/เขต:</div>
                            <div class="patient-value"><%= patient.district %></div>

                            <div class="patient-label">จังหวัด:</div>
                            <div class="patient-value"><%= patient.province %></div>

                        </div>

                        <div class="patient-row">
                            <div class="patient-label">รหัสไปรษณีย์:</div>
                            <div class="patient-value2"><%= patient.postcode %></div>
                        </div>

                        <h4>ข้อมูลติดต่อกรณีฉุกเฉิน</h4>
                        <div class="patient-row">
                            <div class="patient-label">ชื่อ:</div>
                            <div class="patient-value"><%= patient.emergency_fname %></div>

                            <div class="patient-label">นามสกุล:</div>
                            <div class="patient-value"><%= patient.emergency_lname %></div>

                            <div class="patient-label"></div>
                            <div class="patient-value"></div>
                        </div>

                        <div class="patient-row">
                            <div class="patient-label">เบอร์ติดต่อ:</div>
                            <div class="patient-value"><%= patient.emergency_phone %></div>

                            <div class="patient-label">ความสัมพันธ์:</div>
                            <div class="patient-value"><%= patient.relationships %></div>

                            <div class="patient-label"></div>
                            <div class="patient-value"></div>
                        </div>
                    </div>
                    <div>
                        <a href="/examinationroom/<%= patient.id %>" class="menu-btn">ยืนยันมารับบริการ</a>
                    </div>                                   
                    
                <% }); %>
            </div>
        <% } else if (searchTerm) { %>
            <p>ไม่พบข้อมูลผู้ป่วยที่ตรงกับคำค้นหา</p>
        <% } %>
        
    </div>
    
</body>

</html>
