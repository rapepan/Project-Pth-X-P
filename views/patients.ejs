<!DOCTYPE html>
<html lang="th">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link rel="stylesheet" href="/css/patients.css"> <!-- ใช้ CSS เฉพาะหน้า Patients -->
</head>

<body>
    <header>
        <h1>
            <%= title %>
        </h1>
    </header>

    <nav>
        <a href="/index">หน้าหลัก</a>
        <a href="/patients">ข้อมูลผู้ป่วย</a>
        <a href="/patients/add">บันทึกข้อมูลผู้ป่วยใหม่</a>
    </nav>

    <div class="container">
        <h2>ค้นหาผู้ป่วย</h2>
        <!-- ฟอร์มค้นหาผู้ป่วย -->
        <form class="search-bar" action="/patients" method="GET">
            <select name="searchType">
                <option value="HN" <%=searchType==='HN' ? 'selected' : '' %>>ค้นหาด้วย HN</option>
                <option value="name" <%=searchType==='name' ? 'selected' : '' %>>ค้นหาตามชื่อ</option>
                <option value="national_id" <%=searchType==='national_id' ? 'selected' : '' %>>ค้นหาตามรหัสบัตรประชาชน</option>
            </select>
            <input type="text" name="search" placeholder="ค้นหาผู้ป่วย" value="<%= searchTerm %>">
            <button type="submit">ค้นหา</button>
        </form>

        <% if (patients.length > 0 && searchTerm) { %>
            <h3>ผลการค้นหา</h3>
            <!-- แสดงข้อมูลผู้ป่วยในรูปแบบฟอร์ม -->
            <div class="patient-list">
                <% patients.forEach(function(patient) { %>
                    <div class="patient-entry">
                        <div class="patient-row">
                            <div class="patient-label">HN:</div>
                            <div class="patient-value"><%= patient.HN %></div>

                            <div class="patient-label">ชื่อ:</div>
                            <div class="patient-value"><%= patient.name %></div>
                        </div>
                        
                        <div class="patient-row">
                            <div class="patient-label">รหัสประจำตัวประชาชน:</div>
                            <div class="patient-value"><%= patient.national_id %></div>

                            <div class="patient-label">อายุ:</div>
                            <div class="patient-value"><%= patient.age %></div>
                        </div>

                        <div class="patient-row">
                            <div class="patient-label">เพศ:</div>
                            <div class="patient-value"><%= patient.gender %></div>

                            <div class="patient-label">ที่อยู่:</div>
                            <div class="patient-value"><%= patient.address %></div>
                        </div>

                        <div class="patient-row">
                            <div class="patient-label">ส่วนสูง:</div>
                            <div class="patient-value"><%= patient.height %></div>

                            <div class="patient-label">น้ำหนัก:</div>
                            <div class="patient-value"><%= patient.weight %></div>
                        </div>

                        <div class="patient-row">
                            <div class="patient-label">BMI:</div>
                            <div class="patient-value"><%= patient.bmi %></div>

                            <div class="patient-label">ความดันโลหิต:</div>
                            <div class="patient-value"><%= patient.blood_pressure %></div>
                        </div>

                        <div class="patient-row">
                            <div class="patient-label">โรคประจำตัว:</div>
                            <div class="patient-value"><%= patient.chronic_diseases %></div>
                            
                            <div class="patient-label">สาเหตุที่มาพบแพทย์:</div>
                            <div class="patient-value"><%= patient.reason_for_visit %></div>
                        </div>

                        <div class="patient-row">
                            <div class="patient-label">ประวัติการรักษา:</div>
                            <div class="patient-value"><%= patient.treatment_history %></div>
                        </div>

                        <div>
                            <a href="/patients/update/<%= patient.id %>" class="update-link">อัปเดตข้อมูล</a>
                            <a href="/patients/history/<%= patient.id %>">ดูประวัติการรักษา</a>
                        </div>
                        
                    </div>
                <% }); %>
            </div>
        <% } else if (searchTerm) { %>
            <p>ไม่พบข้อมูลผู้ป่วยที่ตรงกับคำค้นหา</p>
        <% } %>
    </div>
</body>

</html>
