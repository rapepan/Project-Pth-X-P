<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600;700&family=Sarabun:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/patients.css">
</head>
<body>
    <header class="sticky-header">
        <div class="header-content">
            <div class="logo-section">
                <h1>
                    <i class="fas fa-users"></i>
                    ค้นหาข้อมูลผู้ป่วย
                </h1>
            </div>
            <div class="logout-section">
                <a href="/index" class="logout-btn">
                    <i class="fas fa-home"></i>
                    <span>กลับหน้าหลัก</span>
                </a>
            </div>
        </div>
    </header>

    <div class="main-container">
        <!-- Hero Section -->
        <div class="hero-section">
            <h1>
                <i class="fas fa-users"></i>
                ค้นหาข้อมูลผู้ป่วย
            </h1>
        </div>

        <!-- Search Section -->
        <div class="search-section">
            <h2 class="search-title">
                <i class="fas fa-search"></i> ค้นหาผู้ป่วย
            </h2>
              
            <form class="search-form" action="/patients" method="GET">
                <div class="form-group">
                    <label class="form-label">ประเภทการค้นหา</label>
                    <select name="searchType" class="form-control">
                        <option value="HN" <%=searchType==='HN' ? 'selected' : '' %>>ค้นหาด้วย HN</option>
                        <option value="fname" <%=searchType==='fname' ? 'selected' : '' %>>ค้นหาตามชื่อ</option>
                        <option value="national_id" <%=searchType==='national_id' ? 'selected' : '' %>>ค้นหาตามรหัสบัตรประชาชน</option>
                    </select>
                </div>
                
                <div class="form-group">
                    <label class="form-label">คำค้นหา</label>
                    <input type="text" name="search" class="form-control" placeholder="กรอกข้อมูลที่ต้องการค้นหา" value="<%= searchTerm %>" autofocus>
                </div>
                
                <button type="submit" class="search-btn">
                    <i class="fas fa-search"></i> ค้นหา
                </button>
            </form>
        </div>

        <!-- Results Section -->
        <% if (patients.length > 0 && searchTerm) { %>
            <div class="results-info">
                <div class="results-count">
                    <i class="fas fa-check-circle"></i> 
                    พบผู้ป่วย <%= patients.length %> ราย
                </div>
                <div>
                    คำค้นหา: "<strong><%= searchTerm %></strong>"
                </div>
            </div>
            
            <div class="patient-list">
                <% patients.forEach(function(patient) { %>
                    <div class="patient-card">
                        <!-- Patient Header -->
                        <div class="patient-header">
                            <div class="patient-header-content">
                                <div class="patient-id">
                                    <div class="patient-avatar">
                                        <%= patient.fname.charAt(0).toUpperCase() %>
                                    </div>
                                    <div class="patient-name-section">
                                        <h3><%= patient.fname %> <%= patient.lname %></h3>
                                        <div class="patient-hn">HN: <%= patient.HN %></div>
                                    </div>
                                </div>
                                <div>
                                    <% if(patient.gender === 'ชาย') { %>
                                        <span class="tag tag-info"><i class="fas fa-mars"></i> ชาย</span>
                                    <% } else { %>
                                        <span class="tag tag-info"><i class="fas fa-venus"></i> หญิง</span>
                                    <% } %>
                                    <span class="tag tag-info"><i class="fas fa-birthday-cake"></i> <%= patient.age %> ปี</span>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Patient Body -->
                        <div class="patient-body">
                            <!-- Personal Info -->
                            <div class="info-section">
                                <h4 class="section-title">
                                    <i class="fas fa-user"></i> ข้อมูลส่วนตัว
                                </h4>
                                <div class="info-grid">
                                    <div class="info-item">
                                        <span class="info-label">รหัสประจำตัวประชาชน</span>
                                        <span class="info-value"><%= patient.national_id %></span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">เบอร์ติดต่อ</span>
                                        <span class="info-value"><i class="fas fa-phone"></i> <%= patient.phone %></span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">วันเกิด</span>
                                        <span class="info-value"><%= new Date(patient.dob).toLocaleDateString('th-TH') %></span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">อายุ</span>
                                        <span class="info-value"><%= patient.age %> ปี</span>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Medical Info -->
                            <div class="info-section">
                                <h4 class="section-title">
                                    <i class="fas fa-notes-medical"></i> ข้อมูลทางการแพทย์
                                </h4>
                                <div class="info-grid">
                                    <div class="info-item">
                                        <span class="info-label">โรคประจำตัว</span>
                                        <span class="info-value">
                                            <% if(patient.chronic_diseases && patient.chronic_diseases !== '-') { %>
                                                <span class="tag tag-danger"><%= patient.chronic_diseases %></span>
                                            <% } else { %>
                                                ไม่มี
                                            <% } %>
                                        </span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">ประวัติการแพ้ยา</span>
                                        <span class="info-value">
                                            <% if(patient.allergy_history && patient.allergy_history !== '-') { %>
                                                <span class="tag tag-danger"><i class="fas fa-exclamation-triangle"></i> <%= patient.allergy_history %></span>
                                            <% } else { %>
                                                ไม่มี
                                            <% } %>
                                        </span>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Address Info -->
                            <div class="info-section">
                                <h4 class="section-title">
                                    <i class="fas fa-map-marker-alt"></i> ที่อยู่
                                </h4>
                                <div class="info-value">
                                    <%= patient.housenumber %> 
                                    <% if(patient.moo && patient.moo !== '-') { %>หมู่ <%= patient.moo %><% } %>
                                    <% if(patient.soi && patient.soi !== '-') { %>ซอย <%= patient.soi %><% } %>
                                    ต.<%= patient.subdistrict %> 
                                    อ.<%= patient.district %> 
                                    จ.<%= patient.province %> 
                                    <%= patient.postcode %>
                                </div>
                            </div>
                            
                            <!-- Emergency Contact -->
                            <div class="info-section">
                                <h4 class="section-title">
                                    <i class="fas fa-phone-alt"></i> ติดต่อฉุกเฉิน
                                </h4>
                                <div class="info-grid">
                                    <div class="info-item">
                                        <span class="info-label">ชื่อผู้ติดต่อ</span>
                                        <span class="info-value"><%= patient.emergency_fname %> <%= patient.emergency_lname %></span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">เบอร์โทร</span>
                                        <span class="info-value"><i class="fas fa-phone"></i> <%= patient.emergency_phone %></span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">ความสัมพันธ์</span>
                                        <span class="info-value"><%= patient.relationships %></span>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Patient Actions -->
                        <div class="patient-actions">
                            <a href="/examinationroom/<%= patient.HN %>" class="action-btn">
                                <i class="fas fa-check-circle"></i> ยืนยันมารับบริการ
                            </a>
                            <a href="/medicaHistorydate/<%= patient.HN %>" class="action-btn action-btn-secondary">
                                <i class="fas fa-history"></i> ดูประวัติผู้ป่วย
                            </a>
                        </div>
                    </div>
                <% }); %>
            </div>
        <% } else if (searchTerm) { %>
            <div class="empty-state">
                <div class="empty-state-icon">
                    <i class="fas fa-search"></i>
                </div>
                <h3 class="empty-state-title">ไม่พบข้อมูลผู้ป่วย</h3>
                <p class="empty-state-text">
                    ไม่พบผู้ป่วยที่ตรงกับคำค้นหา "<strong><%= searchTerm %></strong>"<br>
                    กรุณาตรวจสอบข้อมูลและลองค้นหาใหม่อีกครั้ง
                </p>
            </div>
        <% } else { %>
            <div class="empty-state">
                <div class="empty-state-icon">
                    <i class="fas fa-user-friends"></i>
                </div>
                <h3 class="empty-state-title">เริ่มค้นหาผู้ป่วย</h3>
                <p class="empty-state-text">
                    กรอกข้อมูลในช่องค้นหาด้านบนเพื่อค้นหาผู้ป่วยในระบบ
                </p>
            </div>
        <% } %>
    </div>
</body>
</html>