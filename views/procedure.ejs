<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    
    <!-- Google Fonts สำหรับฟอนต์ไทย -->
    <link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600;700&family=Sarabun:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Font Awesome สำหรับไอคอน -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- CSS ของเรา -->
    <link rel="stylesheet" href="/css/procedure.css">
    
</head>
<body>
    <header class="header">
        <div class="header-content">
            <h1>
                <i class="fas fa-stethoscope"></i>
                <%= title %>
            </h1>
            <div class="user-info">
                <span><%= user.fullname || user.username %></span>
            </div>
        </div>
    </header>

    <nav>
        <a href="/index"><i class="fas fa-home"></i> หน้าหลัก</a>
        <a href="/examinationroom/<%= patient ? patient.HN : '' %>"><i class="fas fa-stethoscope"></i> ห้องตรวจ</a>
        <% if (patient) { %>
            <a href="/procedure/<%= patient.HN %>"  class="active"><i class="fas fa-hand-holding-medical"></i> หัตถการ</a>
            <a href="/billing/<%= patient.HN %>"><i class="fas fa-file-invoice-dollar"></i> สรุปค่าใช้จ่าย</a>
        <% } else { %>
        <% } %>
    </nav>

    <div class="main-container">
        <!-- Alert Messages -->
        <% if (success) { %>
            <div class="alert alert-success">
                <i class="fas fa-check-circle"></i>
                <%= success %>
            </div>
        <% } %>
        
        <% if (error) { %>
            <div class="alert alert-error">
                <i class="fas fa-exclamation-triangle"></i>
                <%= error %>
            </div>
        <% } %>

        <!-- Add Procedure Button Section -->
        <% if (HN) { %>
            <div class="add-procedure-section">
                <div class="section-header">
                    <h2 class="section-title">
                        <i class="fas fa-medkit"></i> หัตถการ
                    </h2>
                </div>
                <div class="add-procedure-card">
                    <div class="card-content">
                        <div class="card-icon">
                            <i class="fas fa-plus-circle"></i>
                        </div>
                        <h3>เพิ่มหัตถการใหม่</h3>
                        <p>เริ่มต้นการรักษาใหม่สำหรับผู้ป่วย HN: <%= HN %></p>
                        <button class="btn-procedure primary" onclick="showCreateProcedureForm()">
                            <i class="fas fa-plus"></i> เพิ่มหัตถการใหม่
                        </button>
                    </div>
                </div>
            </div>
        <% } %>

            <!-- Create Procedure Form Modal -->
        <% if (HN) { %>
            <div id="createProcedureModal" class="modal">
                <div class="modal-content">
                    <div class="modal-header">
                        <h3><i class="fas fa-plus"></i> เพิ่มการรักษาใหม่</h3>
                        <button class="btn-procedure tertiary" onclick="hideCreateProcedureForm()">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>
                    
                    <form class="modal-body" action="/procedure/<%= HN %>" method="POST">
                        <!-- ส่วนเลือกบริการ -->
                        <div class="services-section" data-services='<%= JSON.stringify(services || []) %>'>
                            <h4 class="services-title">
                                <i class="fas fa-search"></i> เลือกบริการ
                            </h4>
                            
                            <!-- ช่องค้นหาบริการ -->
                            <div class="service-search-container">
                                <div class="search-input-wrapper">
                                    <input type="text" id="serviceSearch" class="service-search-input" placeholder="พิมพ์ชื่อบริการเพื่อค้นหา...">
                                    <i class="fas fa-search search-icon"></i>
                                </div>
                                <div id="serviceDropdown" class="service-dropdown" style="display: none;"></div>
                            </div>
                            
                            <!-- รายการบริการที่เลือก -->
                            <div class="selected-services">
                                <h5 class="selected-title">บริการที่เลือก:</h5>
                                <div id="selectedServicesList" class="selected-services-list">
                                    <div class="no-selection">
                                        <p><i class="fas fa-info-circle"></i> ยังไม่ได้เลือกบริการ</p>
                                    </div>
                                </div>
                            </div>

                            <input type="hidden" name="selectedServices" id="selectedServicesInput" value="">
                        </div>
                        
                        <div class="form-row">
                            <div class="form-group">
                                <label class="form-label">ผู้ทำการรักษา</label>
                                <input type="text" name="therapist" class="form-control" placeholder="ชื่อผู้ทำการรักษา">
                            </div>
                            
                            <div class="form-group">
                                <label class="form-label">ระยะเวลา (นาที)</label>
                                <input type="number" name="duration" class="form-control" min="1" placeholder="ระยะเวลาการรักษา">
                            </div>
                        </div>
                        
                        <div class="form-group">
                            <label class="form-label">รายละเอียดเพิ่มเติม</label>
                            <textarea name="techniques" class="form-control" rows="3" placeholder="รายละเอียดเพิ่มเติม"></textarea>
                        </div>
                        
                        <div class="form-group">
                            <label class="form-label">ผลการรักษา</label>
                            <select name="effectiveness" class="form-control">
                                <option value="">เลือกผลการรักษา</option>
                                <option value="good">ดีขึ้น</option>
                                <option value="fair">แย่ลง</option>
                                <option value="poor">คงเดิม</option>
                                <option value="unknown">ยังประเมินไม่ได้</option>
                            </select>
                        </div>
                        
                        <div class="form-group">
                            <label class="form-label">หมายเหตุ</label>
                            <textarea name="notes" class="form-control" rows="3" placeholder="หมายเหตุเพิ่มเติม"></textarea>
                        </div>
                        
                        <div class="form-actions">
                            <button type="button" class="btn-procedure secondary" onclick="hideCreateProcedureForm()">
                                <i class="fas fa-times"></i> ยกเลิก
                            </button>
                            <button type="submit" class="btn-procedure primary">
                                <i class="fas fa-save"></i> บันทึกหัตถการ
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        <% } else { %>
            <div class="empty-state">
                <div class="empty-state-icon">
                    <i class="fas fa-search"></i>
                </div>
                <h3 class="empty-state-title">ค้นหาผู้ป่วยเพื่อบันทึกการรักษา</h3>
                <p class="empty-state-text">
                    กรอกข้อมูลในช่องค้นหาด้านบนเพื่อค้นหาผู้ป่วยและบันทึกการรักษา
                </p>
            </div>
        <% } %>
    </div>

    <!-- JavaScript -->
    <script src="/js/procedure.js"></script>
    <script src="/js/notifications.js"></script>

<script>
    // ฟังก์ชันสำหรับจัดการการเลือกบริการ
    document.addEventListener('DOMContentLoaded', function() {
        // ดึงข้อมูลบริการจาก data attribute
        const servicesSection = document.querySelector('.services-section');
        if (!servicesSection) return; // ถ้าไม่มี services section ให้ออก
        
        const services = JSON.parse(servicesSection.dataset.services || '[]');
        
        const serviceSearchInput = document.getElementById('serviceSearch');
        const serviceDropdown = document.getElementById('serviceDropdown');
        const selectedServicesList = document.getElementById('selectedServicesList');
        const selectedServicesInput = document.getElementById('selectedServicesInput');

        let selectedServices = [];
        let filteredServices = [];
        
        // เมื่อพิมพ์ในช่องค้นหา
        serviceSearchInput.addEventListener('input', function() {
            const searchTerm = this.value.toLowerCase().trim();
            
            if (searchTerm.length < 2) {
                serviceDropdown.style.display = 'none';
                return;
            }
            
            // ค้นหาบริการที่ตรงกับคำค้นหา
            filteredServices = services.filter(service => 
                service.service_name.toLowerCase().includes(searchTerm)
            );
            
            if (filteredServices.length > 0) {
                showDropdown(filteredServices);
            } else {
                serviceDropdown.style.display = 'none';
            }
        });
        
        // ซ่อน dropdown เมื่อคลิกข้างนอก
        document.addEventListener('click', function(e) {
            if (!serviceSearchInput.contains(e.target) && !serviceDropdown.contains(e.target)) {
                serviceDropdown.style.display = 'none';
            }
        });
        
        // แสดง dropdown
        function showDropdown(services) {
            serviceDropdown.innerHTML = '';
            
            services.forEach(service => {
                const serviceItem = document.createElement('div');
                serviceItem.className = 'dropdown-item';
                serviceItem.innerHTML = `
                    <div class="service-info">
                        <h6 class="service-name">${service.service_name}</h6>
                    </div>
                `;
                
                serviceItem.addEventListener('click', function() {
                    addService(service);
                    serviceSearchInput.value = '';
                    serviceDropdown.style.display = 'none';
                });
                
                serviceDropdown.appendChild(serviceItem);
            });
            
            serviceDropdown.style.display = 'block';
        }
        
        // เพิ่มบริการ
        function addService(service) {
            // ตรวจสอบว่าบริการนี้ถูกเลือกแล้วหรือไม่
            if (selectedServices.find(s => s.id === service.id)) {
                alert('บริการนี้ถูกเลือกแล้ว');
                return;
            }

            selectedServices.push(service);
            updateSelectedServicesList();
        }
        
        // อัปเดตรายการบริการที่เลือก
        function updateSelectedServicesList() {
            if (selectedServices.length === 0) {
                selectedServicesList.innerHTML = `
                    <div class="no-selection">
                        <p><i class="fas fa-info-circle"></i> ยังไม่ได้เลือกบริการ</p>
                    </div>
                `;
                selectedServicesInput.value = '';
                return;
            }

            selectedServicesList.innerHTML = '';

            selectedServices.forEach((service, index) => {
                const serviceItem = document.createElement('div');
                serviceItem.className = 'selected-service-item';
                serviceItem.innerHTML = `
                    <div class="service-info">
                        <h6 class="service-name">${service.service_name}</h6>
                    </div>
                    <div class="service-actions">
                        <button type="button" class="remove-btn" onclick="removeService(${index})">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>
                `;

                selectedServicesList.appendChild(serviceItem);
            });

            // อัปเดต hidden input
            selectedServicesInput.value = JSON.stringify(selectedServices);
        }
        
        // ลบบริการ
        window.removeService = function(index) {
            selectedServices.splice(index, 1);
            updateSelectedServicesList();
        };
        
        // ตรวจสอบการเลือกบริการก่อนส่งฟอร์ม
        document.querySelector('form').addEventListener('submit', function(e) {
            if (selectedServices.length === 0) {
                e.preventDefault();
                alert('กรุณาเลือกบริการอย่างน้อย 1 รายการ');
                return false;
            }
        });
    });
</script>
</body>
</html>
