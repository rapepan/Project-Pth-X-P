<!DOCTYPE html>
<html lang="th">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>อัปเดตข้อมูลผู้ป่วย - <%= title %>
    </title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 0;
            background-color: #f4f4f4;
        }

        header {
            background-color: #007BFF;
            padding: 10px;
            color: white;
            text-align: center;
        }

        nav {
            background-color: #333;
            overflow: hidden;
        }

        nav a {
            float: left;
            display: block;
            color: white;
            padding: 14px 20px;
            text-align: center;
            text-decoration: none;
        }

        nav a:hover {
            background-color: #ddd;
            color: black;
        }

        .container {
            padding: 20px;
        }

        .update-form {
            margin-top: 20px;
            border: 1px solid #ddd;
            padding: 20px;
            background-color: #f9f9f9;
        }

        .update-form input {
            margin-bottom: 10px;
            padding: 10px;
            font-size: 16px;
            width: 100%;
        }

        .update-form button {
            padding: 10px 20px;
            background-color: #28a745;
            color: white;
            border: none;
            font-size: 16px;
            cursor: pointer;
        }

        .update-form button:hover {
            background-color: #218838;
        }
    </style>
</head>

<body>
    <header>
        <h1>อัปเดตข้อมูลผู้ป่วย - <%= title %>
        </h1>
    </header>

    <nav>
        <a href="/">หน้าหลัก</a>
        <a href="/patients">ข้อมูลผู้ป่วย</a>
    </nav>

    <div class="container">
        <h2>อัปเดตข้อมูลผู้ป่วย</h2>

        <!-- ฟอร์มอัปเดตข้อมูลผู้ป่วย -->
        <form class="update-form" action="/patients/update/<%= patient.id %>" method="POST">
            <label for="height">ส่วนสูง</label>
            <input type="text" id="height" name="height" value="<%= patient.height %>" required>

            <label for="weight">น้ำหนัก</label>
            <input type="text" id="weight" name="weight" value="<%= patient.weight %>" required>

            <label for="bmi">BMI</label>
            <input type="text" id="bmi" name="bmi" value="<%= patient.bmi %>" required>

            <label for="blood_pressure">ความดันโลหิต</label>
            <input type="text" id="blood_pressure" name="blood_pressure" value="<%= patient.blood_pressure %>" required>

            <label for="treatment_history">ประวัติการรักษา</label>
            <textarea id="treatment_history" name="treatment_history" rows="4"
                required><%= patient.treatment_history %></textarea>

            <button type="submit">อัปเดตข้อมูล</button>
        </form>
    </div>
</body>

</html>